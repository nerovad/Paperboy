#!/bin/bash
set -e

APP_DIR="/home/matthew/gitea/Paperboy"
BRANCH="${1:-master}"
cd "$APP_DIR"

echo "==> Fetching and checking out branch: $BRANCH ..."
git fetch origin
git checkout "$BRANCH"
git pull origin "$BRANCH"

echo "==> Installing gems..."
bundle install --without development test

echo "==> Clobbering old assets..."
RAILS_ENV=staging bundle exec rails assets:clobber

echo "==> Precompiling assets..."
RAILS_ENV=staging bundle exec rails assets:precompile

echo "==> Restarting Puma..."
sudo systemctl restart paperboy-stage

echo "==> Restarting Sidekiq..."
sudo systemctl restart paperboy-stage-sidekiq

echo "==> Stage deploy complete!"
