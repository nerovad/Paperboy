<section class="coa-page">
  <div class="coa-header">
    <div>
      <h1><%= collection_title %></h1>
      <p class="coa-subtitle">Review and maintain chart of account values.</p>
    </div>
    <div class="coa-header-actions">
      <%= link_to "COA list", coa_root_path, class: "form-btn form-btn--secondary" %>
    </div>
  </div>

  <div class="table-wrapper coa-table-wrapper">
    <table class="submission-table coa-table">
      <thead>
        <tr>
          <% display_columns.each do |column_name| %>
            <th><%= column_name.humanize %></th>
          <% end %>
          <th class="coa-actions-column">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% records.each do |row| %>
          <tr>
            <% display_columns.each do |column_name| %>
              <td><%= row.public_send(column_name) %></td>
            <% end %>
            <td class="coa-actions">
              <%= link_to "Show", member_path(row), class: "form-btn form-btn--secondary" %>
              <%= link_to "Edit", edit_record_path(row), class: "form-btn" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
