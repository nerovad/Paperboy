<!-- Generated by Paperboy Form Builder -->
<div class="form-header">
  <h1>Form Request</h1>
</div>

<div class="form-wrapper" data-controller="form-navigation conditional-fields">
  <%= form_with model: @form_request_form, local: true do |form| %>

  <% if @form_request_form.errors.any? %>
    <div class="form-errors" role="alert" data-form-navigation-target="errorSummary">
      <strong><%= pluralize(@form_request_form.errors.count, "error") %> prevented this form from being submitted:</strong>
      <ul>
        <% @form_request_form.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

        <% _page_1_visible = true %>
        <% _page_2_visible = true %>
        <% _page_3_visible = true %>
        <% _page_4_visible = true %>
        <% _page_5_visible = true %>
        <% _page_6_visible = true %>
        <% _page_7_visible = true %>
        <% _visible_page_count = [_page_1_visible, _page_2_visible, _page_3_visible, _page_4_visible, _page_5_visible, _page_6_visible, _page_7_visible].count(true) %>

<!-- Page 1: Employee Info -->
<div class="form-page">
  <h2>Employee Info</h2>
<div class="form-row d-flex flex-wrap">
  <div class="form-group flex-fill">
    <%= form.label :employee_id, "Employee ID" %>
    <%= form.text_field :employee_id,
          value: @prefill_data[:employee_id],
          class: "form-control",
          readonly: true %>
  </div>

  <div class="form-group flex-fill">
    <%= form.label :name, "Name" %>
    <%= form.text_field :name,
          value: @prefill_data[:name],
          class: "form-control",
          readonly: true %>
  </div>

  <div class="form-group flex-fill">
    <%= form.label :phone, "Phone" %>
    <%= form.text_field :phone,
          value: @prefill_data[:phone],
          class: "form-control",
          required: true,
          placeholder: "e.g. 555-555-5555",
          title: "Enter a 10-digit phone number like 555-555-5555",
          data: {
            controller: "phone",
            phone_target: "input",
            action: "input->phone#format paste->phone#format blur->phone#validate"
          },
          "aria-describedby": "phoneHelp phoneError",
          pattern: "\\d{3}-\\d{3}-\\d{4}",
          inputmode: "numeric",
          autocomplete: "tel" %>
    <small id="phoneHelp" class="help-text text-muted"></small>
    <div id="phoneError" data-phone-target="error" class="field-error" aria-live="polite"></div>
  </div>

  <div class="form-group flex-fill">
    <%= form.label :email, "Email" %>
    <%= form.text_field :email,
          value: @prefill_data[:email],
          class: "form-control",
          required: true %>
  </div>
</div>
      </div>

<!-- Page 2: Agency Info -->
<div class="form-page" style="display:none;">
  <h2>Agency Info</h2>
<div data-controller="gsabss-selects" class="form-row d-flex flex-wrap">
  <div class="form-group">
    <%= form.label :agency, "Agency" %>
    <%= form.select :agency,
          options_for_select(@agency_options, @prefill_data[:agency]),
          {},
          class: "form-control",
          id: "agency-select",
          data: {
            gsabss_selects_target: "agency",
            action: "change->gsabss-selects#loadDivisions"
          } %>
  </div>

  <div class="form-group">
    <%= form.label :division, "Division" %>
    <%= form.select :division,
          options_for_select(@division_options, @prefill_data[:division]),
          {},
          class: "form-control",
          id: "division-select",
          data: {
            gsabss_selects_target: "division",
            action: "change->gsabss-selects#loadDepartments"
          } %>
  </div>

  <div class="form-group">
    <%= form.label :department, "Department" %>
    <%= form.select :department,
          options_for_select(@department_options, @prefill_data[:department]),
          {},
          class: "form-control",
          id: "department-select",
          data: {
            gsabss_selects_target: "department",
            action: "change->gsabss-selects#loadUnits"
          } %>
  </div>

  <div class="form-group">
    <%= form.label :unit, "Unit" %>
    <%= form.select :unit,
          options_for_select(@unit_options, @prefill_data[:unit]),
          {},
          class: "form-control",
          id: "unit-select",
          data: { gsabss_selects_target: "unit" } %>
  </div>
</div>
      </div>

<!-- Page 3: About -->
<div class="form-page" style="display:none;">
  <h2>About</h2>
        <div class="form-row d-flex flex-wrap">
<!-- FIELD:about_the_form START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :about_the_form, "About the Form" %>
            <%= form.text_area :about_the_form, rows: 7, class: "form-control" %>
          </div>
<!-- FIELD:about_the_form END -->
        </div>
      </div>

<!-- Page 4: Fields -->
<div class="form-page" style="display:none;">
  <h2>Fields</h2>
        <div class="form-row d-flex flex-wrap">
<!-- FIELD:list_all_fields_on_form START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :list_all_fields_on_form, "List all Fields on Form" %>
            <%= form.text_area :list_all_fields_on_form, rows: 10, class: "form-control" %>
          </div>
<!-- FIELD:list_all_fields_on_form END -->
<!-- FIELD:attach_existing_pdf_form START --><div class="form-group flex-fill<%= '' %>" data-controller="file-preview" data-file-preview-max-value="10">
  <%= form.label :attach_existing_pdf_form, "Attach Existing PDF Form" %>
            <%= form.file_field :attach_existing_pdf_form, multiple: true, class: "form-control", direct_upload: true, accept: "image/jpeg,image/png,image/gif,image/webp,image/heic,image/heif,application/pdf", data: { file_preview_target: "input", action: "change->file-preview#preview" } %>
            <small class="form-text text-muted">You can select files multiple times — up to 10 total. <span data-file-preview-target="count"></span></small>
            <div data-file-preview-target="preview" class="file-preview-grid"></div>
          </div>
<!-- FIELD:attach_existing_pdf_form END -->
        </div>
      </div>

<!-- Page 5: Routing -->
<div class="form-page" style="display:none;">
  <h2>Routing</h2>
        <div class="form-row d-flex flex-wrap">
<!-- FIELD:form_routing START --><div class="form-group flex-fill<%= '' %>" data-controller="choices">
  <%= form.label :form_routing, "Form Routing" %>
            <%= form.select :form_routing,
                  options_for_select(['Database', 'Supervisor', 'Group', 'Specific Employee', 'Other']),
                  { include_blank: false },
                  { class: "form-control", multiple: true, data: { choices_target: "select", placeholder: "Select options...", conditional_trigger: 'form_routing' } } %>
          </div>
<!-- FIELD:form_routing END -->
<!-- FIELD:specific_employee START -->          <div class="conditional-field" data-depends-on="form_routing" data-show-values="[&quot;Specific Employee&quot;]" style="display: none;">
<div class="form-group flex-fill<%= '' %>" data-controller="choices">
  <%= form.label :specific_employee, "Specific Employee" %>
            <%= form.select :specific_employee,
                  options_for_select(Employee.order(:last_name).map { |e| "#{e.last_name}, #{e.first_name}" }),
                  { include_blank: false },
                  { class: "form-control", multiple: true, data: { choices_target: "select", placeholder: "Select options..." } } %>
          </div>
          </div>
<!-- FIELD:specific_employee END -->
<!-- FIELD:other_routing START -->          <div class="conditional-field" data-depends-on="form_routing" data-show-values="[&quot;Other&quot;]" style="display: none;">
<div class="form-group flex-fill<%= '' %>">
  <%= form.label :other_routing, "Other Routing" %>
            <%= form.text_field :other_routing, class: "form-control" %>
          </div>
          </div>
<!-- FIELD:other_routing END -->
<!-- FIELD:group_name START -->          <div class="conditional-field" data-depends-on="form_routing" data-show-values="[&quot;Group&quot;]" style="display: none;">
<div class="form-group flex-fill<%= '' %>">
  <%= form.label :group_name, "Group Name" %>
            <%= form.text_field :group_name, class: "form-control" %>
          </div>
          </div>
<!-- FIELD:group_name END -->
<!-- FIELD:employees_in_group START -->          <div class="conditional-field" data-depends-on="form_routing" data-show-values="[&quot;Group&quot;]" style="display: none;">
<div class="form-group flex-fill<%= '' %>" data-controller="choices">
  <%= form.label :employees_in_group, "Employees in Group" %>
            <%= form.select :employees_in_group,
                  options_for_select(Employee.order(:last_name).map { |e| "#{e.last_name}, #{e.first_name}" }),
                  { include_blank: false },
                  { class: "form-control", multiple: true, data: { choices_target: "select", placeholder: "Select options..." } } %>
          </div>
          </div>
<!-- FIELD:employees_in_group END -->
        </div>
      </div>

<!-- Page 6: Notifications -->
<div class="form-page" style="display:none;">
  <h2>Notifications</h2>
        <div class="form-row d-flex flex-wrap">
<!-- FIELD:email_or_teams_notifications START --><div class="form-group flex-fill<%= '' %>" data-controller="choices">
  <%= form.label :email_or_teams_notifications, "Email or Teams Notifications" %>
            <%= form.select :email_or_teams_notifications,
                  options_for_select(['Email', 'Teams', 'Other']),
                  { include_blank: false },
                  { class: "form-control", multiple: true, data: { choices_target: "select", placeholder: "Select options..." } } %>
          </div>
<!-- FIELD:email_or_teams_notifications END -->
<!-- FIELD:other_notification START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :other_notification, "Other Notification" %>
            <%= form.text_field :other_notification, class: "form-control" %>
          </div>
<!-- FIELD:other_notification END -->
        </div>
      </div>

<!-- Page 7: Extras -->
<div class="form-page" style="display:none;">
  <h2>Extras</h2>
      </div>

    <!-- Navigation Buttons -->
    <div class="navigation-buttons d-flex justify-content-between">
      <div>
        <button type="button" id="prevBtn" data-action="click->form-navigation#prevPage" style="display:none;">Previous</button>
      </div>
      <div>
        <button type="button" id="nextBtn" data-action="click->form-navigation#nextPage">Next</button>
        <%= form.submit "Submit", data: { form_navigation_target: "submitButton" }, style: "display:none;" %>
      </div>
    </div>

    <!-- Progress (7 steps) -->
    <div class="progress-wrapper">
      <div class="progress-bar-container">
        <div class="progress-bar" id="progressBar"></div>
      </div>
      <div class="progress-dots">
        <% _visible_page_count.times do |index| %>
          <div class="dot <%= 'active' if index == 0 %>"></div>
        <% end %>
      </div>
    </div>

  <% end %>
</div>
