<!-- app/views/contractor_passwords/edit.html.erb -->
<div class="form-header">
  <h1>Set Your Password</h1>
</div>

<div class="form-wrapper">
  <p class="form-intro">
    Choose a password for <strong><%= @contractor.email %></strong>. It must be at
    least <%= ContractorPasswordsController::MIN_PASSWORD_LENGTH %> characters.
  </p>

  <%= form_with url: contractor_password_path, method: :patch, local: true do %>
    <%= hidden_field_tag :token, @token %>

    <div class="form-group">
      <%= label_tag :password, "New password" %>
      <%= password_field_tag :password, nil, required: true, autofocus: true,
            autocomplete: "new-password", class: "form-control" %>
    </div>

    <div class="form-group">
      <%= label_tag :password_confirmation, "Confirm password" %>
      <%= password_field_tag :password_confirmation, nil, required: true,
            autocomplete: "new-password", class: "form-control" %>
    </div>

    <div class="form-actions">
      <%= submit_tag "Save password", class: "btn approve" %>
    </div>
  <% end %>
</div>
