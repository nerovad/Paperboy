<div id="status-history-modal"
     class="deny-modal-backdrop"
     data-status-history-modal-target="backdrop"
     style="display:none;">
  <div class="deny-modal status-history-modal" data-status-history-modal-target="modal"
       role="dialog" aria-modal="true" aria-labelledby="status-history-modal-title">
    <div class="deny-modal__header">
      <h3 id="status-history-modal-title" data-status-history-modal-target="title">Status History</h3>
      <button type="button" class="deny-modal__close" data-action="status-history-modal#close" aria-label="Close">✕</button>
    </div>

    <div class="deny-modal__body" data-status-history-modal-target="body">
      <p class="status-history-modal__loading">Loading…</p>
    </div>
  </div>
</div>
