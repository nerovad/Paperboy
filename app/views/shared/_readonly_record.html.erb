<!-- app/views/shared/_readonly_record.html.erb -->
<dl class="readonly-form">
  <% excluded = Array(exclude) + %w[id created_at updated_at] %>

  <% if (reference = FormReference.reference_for(record)).present? %>
    <dt>Reference</dt>
    <dd><span class="reference-badge"><%= reference %></span></dd>
  <% end %>

  <% record.attribute_names.each do |attr| %>
    <% next if excluded.include?(attr) %>

    <dt><%= attr.humanize %></dt>
    <dd>
      <% value =
           if attr == "status" && record.respond_to?(:status_label)
             record.status_label
           elsif record.respond_to?("#{attr}_display")
             record.public_send("#{attr}_display")
           elsif record.respond_to?("#{attr}_long_name")
             record.public_send("#{attr}_long_name")
           else
             record.public_send(attr)
           end %>

      <%# Nicely format dates/times %>
      <% if value.is_a?(Date) || value.is_a?(Time) || value.is_a?(ActiveSupport::TimeWithZone) %>
        <%= l(value) %>
      <% else %>
        <%= value.to_s %>
      <% end %>
    </dd>
  <% end %>
</dl>

<%# Workflow lifecycle: when each step was approved/denied and by whom.
    Shown on every submission detail page that renders this partial. %>
<% if record.respond_to?(:status_timeline) %>
  <% timeline = record.status_timeline.to_a %>
  <% if timeline.any? %>
    <section class="workflow-history" style="margin-top: 24px;">
      <h3>Workflow History</h3>
      <%= render partial: "submissions/status_timeline",
                 locals: { status_changes: timeline, item_id: record.id } %>
    </section>
  <% end %>
<% end %>
