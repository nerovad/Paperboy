<%# Tab bar shared by the Admin portal pages (ACL, Manage Forms, Emulate, Data
    Validation). `active` is the tab's ACL key as a symbol, e.g. :acl. Tab
    visibility mirrors the navbar permission checks so a user only ever sees
    (and can switch to) tabs they're allowed to view. %>
<nav class="admin-tabs" aria-label="Admin">
  <% admin_portal_tabs.each do |tab| %>
    <% current = tab[:key].to_sym == active %>
    <%= link_to tab[:path],
        class: "admin-tab admin-tab--#{tab[:key].dasherize} #{'is-active' if current}",
        aria: { current: ("page" if current) } do %>
      <%= tab[:label] %>
    <% end %>
  <% end %>
</nav>
