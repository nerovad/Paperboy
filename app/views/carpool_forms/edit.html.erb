<!-- Generated by Paperboy Form Builder -->
<div class="form-header">
  <h1>Edit Carpool</h1>
</div>

<div class="form-wrapper" data-controller="form-navigation">
  <%= form_with model: @carpool_form, local: true do |form| %>

<!-- Page 1: Employee Info -->
<div class="form-page">
  <h2>Employee Info</h2>
<div class="form-row d-flex flex-wrap">
  <div class="form-group flex-fill">
    <%= form.label :employee_id, "Employee ID" %>
    <%= form.text_field :employee_id,
          class: "form-control",
          readonly: true %>
  </div>

  <div class="form-group flex-fill">
    <%= form.label :name, "Name" %>
    <%= form.text_field :name,
          class: "form-control",
          readonly: true %>
  </div>

  <div class="form-group flex-fill">
    <%= form.label :phone, "Phone" %>
    <%= form.text_field :phone,
          class: "form-control",
          required: true,
          placeholder: "e.g. 555-555-5555",
          title: "Enter a 10-digit phone number like 555-555-5555",
          data: {
            controller: "phone",
            phone_target: "input",
            action: "input->phone#format paste->phone#format blur->phone#validate"
          },
          "aria-describedby": "phoneHelp phoneError",
          pattern: "\\d{3}-\\d{3}-\\d{4}",
          inputmode: "numeric",
          autocomplete: "tel" %>
    <small id="phoneHelp" class="help-text text-muted"></small>
    <div id="phoneError" data-phone-target="error" class="field-error" aria-live="polite"></div>
  </div>

  <div class="form-group flex-fill">
    <%= form.label :email, "Email" %>
    <%= form.text_field :email,
          class: "form-control",
          required: true %>
  </div>
</div>
      </div>

<!-- Page 2: Agency Info -->
<div class="form-page" style="display:none;">
  <h2>Agency Info</h2>
<div data-controller="gsabss-selects" class="form-row d-flex flex-wrap">
  <div class="form-group">
    <%= form.label :agency, "Agency" %>
    <%= form.select :agency,
          options_for_select(@agency_options, @carpool_form.agency),
          {},
          class: "form-control",
          id: "agency-select",
          data: {
            gsabss_selects_target: "agency",
            action: "change->gsabss-selects#loadDivisions"
          } %>
  </div>

  <div class="form-group">
    <%= form.label :division, "Division" %>
    <%= form.select :division,
          options_for_select(@division_options, @carpool_form.division),
          {},
          class: "form-control",
          id: "division-select",
          data: {
            gsabss_selects_target: "division",
            action: "change->gsabss-selects#loadDepartments"
          } %>
  </div>

  <div class="form-group">
    <%= form.label :department, "Department" %>
    <%= form.select :department,
          options_for_select(@department_options, @carpool_form.department),
          {},
          class: "form-control",
          id: "department-select",
          data: {
            gsabss_selects_target: "department",
            action: "change->gsabss-selects#loadUnits"
          } %>
  </div>

  <div class="form-group">
    <%= form.label :unit, "Unit" %>
    <%= form.select :unit,
          options_for_select(@unit_options, @carpool_form.unit),
          {},
          class: "form-control",
          id: "unit-select",
          data: { gsabss_selects_target: "unit" } %>
  </div>
</div>
      </div>

<!-- Page 3: Participants -->
<div class="form-page" style="display:none;">
  <h2>Participants</h2>
        <div class="form-row d-flex flex-wrap">
<!-- FIELD:passengers START --><div class="form-group flex-fill<%= '' %>" data-controller="choices">
  <%= form.label :passengers, "Passengers" %>
            <%= form.select :passengers,
                  options_for_select(Employee.order(:Last_Name).map { |e| "#{e.last_name}, #{e.first_name}" }),
                  { include_blank: false },
                  { class: "form-control", multiple: true, data: { choices_target: "select", placeholder: "Select options..." } } %>
          </div>
<!-- FIELD:passengers END -->
        </div>
      </div>

<!-- Page 4: Vehicle Info -->
<div class="form-page" style="display:none;">
  <h2>Vehicle Info</h2>
        <div class="form-row d-flex flex-wrap">
<!-- FIELD:year START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :year, "Year" %>
            <%= form.text_field :year, class: "form-control", required: true %>
          </div>
<!-- FIELD:year END -->
<!-- FIELD:make START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :make, "Make" %>
            <%= form.text_field :make, class: "form-control", required: true %>
          </div>
<!-- FIELD:make END -->
<!-- FIELD:model START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :model, "Model" %>
            <%= form.text_field :model, class: "form-control", required: true %>
          </div>
<!-- FIELD:model END -->
<!-- FIELD:license_plate START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :license_plate, "License Plate" %>
            <%= form.text_field :license_plate, class: "form-control", required: true %>
          </div>
<!-- FIELD:license_plate END -->
<!-- FIELD:color START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :color, "Color" %>
            <%= form.text_field :color, class: "form-control", required: true %>
          </div>
<!-- FIELD:color END -->
<!-- FIELD:drivers_license_ START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :drivers_license_, "Drivers License #" %>
            <%= form.text_field :drivers_license_, class: "form-control", required: true %>
          </div>
<!-- FIELD:drivers_license_ END -->
        </div>
      </div>

<!-- Page 5: Additional Information -->
<div class="form-page" style="display:none;">
  <h2>Additional Information</h2>
        <div class="form-row d-flex flex-wrap">
<!-- FIELD:final_location START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :final_location, "Final Location" %>
            <%= form.select :final_location,
                  options_for_select(['Yes', 'No'], @carpool_form.final_location),
                  { include_blank: "Select..." },
                  { class: "form-control", required: true } %>
          </div>
<!-- FIELD:final_location END -->
<!-- FIELD:carpool_origin_zip START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :carpool_origin_zip, "Carpool Origin Zip" %>
            <%= form.select :carpool_origin_zip,
                  options_for_select(['Yes', 'No'], @carpool_form.carpool_origin_zip),
                  { include_blank: "Select..." },
                  { class: "form-control", required: true } %>
          </div>
<!-- FIELD:carpool_origin_zip END -->
<!-- FIELD:vacant_seats START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :vacant_seats, "Vacant Seats?" %>
            <%= form.select :vacant_seats,
                  options_for_select(['Yes', 'No'], @carpool_form.vacant_seats),
                  { include_blank: "Select..." },
                  { class: "form-control", required: true } %>
          </div>
<!-- FIELD:vacant_seats END -->
<!-- FIELD:willing_to_add_more_people START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :willing_to_add_more_people, "Willing to Add More People?" %>
            <%= form.select :willing_to_add_more_people,
                  options_for_select(['Yes', 'No'], @carpool_form.willing_to_add_more_people),
                  { include_blank: "Select..." },
                  { class: "form-control", required: true } %>
          </div>
<!-- FIELD:willing_to_add_more_people END -->
        </div>
      </div>

    <!-- Navigation Buttons -->
    <div class="navigation-buttons d-flex justify-content-between">
      <div>
        <button type="button" id="prevBtn" data-action="click->form-navigation#prevPage" style="display:none;">Previous</button>
      </div>
      <div>
        <button type="button" id="nextBtn" data-action="click->form-navigation#nextPage">Next</button>
        <%= form.submit "Update", data: { form_navigation_target: "submitButton" }, style: "display:none;" %>
      </div>
    </div>

    <!-- Progress (5 steps) -->
    <div class="progress-wrapper">
      <div class="progress-bar-container">
        <div class="progress-bar" id="progressBar"></div>
      </div>
      <div class="progress-dots">
        <% 5.times do |index| %>
          <div class="dot <%= 'active' if index == 0 %>"></div>
        <% end %>
      </div>
    </div>

  <% end %>
</div>
