<%# Renders inbox action buttons for dynamically generated forms based on form template configuration %>
<%# Usage: render 'inbox/dynamic_buttons', submission: submission %>

<% template = form_template_for(submission) %>
<% return unless template %>
<%
  viewer_id = session.dig(:user, "employee_id").to_s
  current_step = current_routing_step_for(submission, template)
  approver_id_match = submission.respond_to?(:approver_id) && submission.approver_id.to_s == viewer_id && viewer_id.present?
  copy_row = approver_id_match ? nil : copy_row_for(submission)
  # A tracking copy left behind by an earlier pool step shouldn't mask the
  # approve button when the viewer is once again a live approver at the step the
  # form is currently sitting at — e.g. two consecutive group steps routed to the
  # same group, where approver_id stays nil so approver_id_match can't catch it.
  # Gated behind copy_row so the eligibility lookup only runs for the few rows
  # that actually have a copy to suppress.
  if copy_row && current_step && viewer_id.present? &&
     current_step.eligible_approver_ids(submission).map(&:to_s).include?(viewer_id)
    copy_row = nil
  end
%>
<% if copy_row %>
  <span class="badge" style="background: #6c757d; color: #fff; padding: 2px 8px; border-radius: 10px; font-size: 0.75em; margin-right: 8px;">Copy</span>

  <% pdf_path = inbox_pdf_path(submission) %>
  <% if pdf_path %>
    <%= link_to "View PDF", pdf_path, class: "btn pdf", target: "_blank", data: { turbo: false } %>
  <% end %>

  <%= button_to "Dismiss",
        dismiss_form_submission_copy_path(copy_row),
        method: :delete,
        class: "btn deny",
        form: { data: { turbo: false } } %>
<% else %>
<% button_source = current_step || template %>

<!-- View PDF -->
<% if button_source.inbox_button?('view_pdf') %>
  <% pdf_path = inbox_pdf_path(submission) %>
  <% if pdf_path %>
    <%= link_to "View PDF", pdf_path, class: "btn pdf", target: "_blank", data: { turbo: false } %>
  <% end %>
<% end %>

<!-- Edit -->
<% if button_source.inbox_button?('edit') %>
  <% edit_path = inbox_edit_path(submission) %>
  <% if edit_path %>
    <%= link_to "Edit", edit_path, class: "btn edit", data: { turbo: false } %>
  <% end %>
<% end %>

<!-- Status Dropdown -->
<% if button_source.inbox_button?('status_dropdown') %>
  <% status_path = inbox_update_status_path(submission) %>
  <% status_options = inbox_status_options(submission) %>
  <% if status_path && status_options.any? %>
    <%= form_with url: status_path,
                  method: :patch,
                  data: { turbo: false, controller: "auto-submit" } do |f| %>
      <%= f.select :status,
          options_for_select(status_options, submission.status),
          {},
          class: "status-dropdown",
          data: { action: "change->auto-submit#submit" } %>
    <% end %>
  <% end %>
<% end %>

<!-- Approve -->
<% if button_source.inbox_button?('approve') %>
  <% approve_path = inbox_approve_path(submission) %>
  <% if approve_path %>
    <% approve_label = button_source.respond_to?(:approve_button_text) ? button_source.approve_button_text : "Approve" %>
    <%= button_to approve_label,
          approve_path,
          method: :patch,
          class: "btn approve" %>
  <% end %>
<% end %>

<!-- Deny -->
<% if button_source.inbox_button?('deny') %>
  <% deny_path = inbox_deny_path(submission) %>
  <% if deny_path %>
    <% deny_label = button_source.respond_to?(:deny_button_text) ? button_source.deny_button_text : "Deny" %>
    <button type="button"
            class="btn deny"
            data-action="click->deny-modal#open"
            data-deny-path="<%= deny_path %>"
            data-record-title="<%= "#{submission.class.name.demodulize.titleize} #{inbox_reference(submission)}" %>">
      <%= deny_label %>
    </button>
  <% end %>
<% end %>

<!-- Reassign -->
<% if button_source.inbox_button?('reassign') %>
  <button type="button"
          class="btn reassign"
          data-action="click->reassign-modal#open"
          data-task-type="<%= submission.class.name %>"
          data-task-id="<%= submission.id %>"
          data-current-assignee="<%= submission.respond_to?(:current_assignee_id) ? submission.current_assignee_id : '' %>">
    Reassign
  </button>
<% end %>

<!-- Take Back -->
<% if button_source.inbox_button?('take_back') %>
  <% if submission.respond_to?(:can_take_back?) && submission.can_take_back?(session.dig(:user, "employee_id")) %>
    <%= button_to "Take Back",
          take_back_task_reassignments_path,
          method: :post,
          params: {
            task_type: submission.class.name,
            task_id: submission.id,
            to_employee_id: session.dig(:user, "employee_id")
          },
          class: "btn take-back",
          form: { data: { turbo: false } } %>
  <% end %>
<% end %>

<!-- Status History -->
<% if button_source.inbox_button?('status_history') %>
  <button type="button"
          class="btn status-history"
          data-action="click->status-history-modal#open"
          data-history-url="<%= inbox_status_history_path(type: submission.class.name, id: submission.id) %>"
          data-record-title="<%= "#{submission.class.name.demodulize.titleize} ##{submission.id}" %>">
    Status History
  </button>
<% end %>
<% end %>
