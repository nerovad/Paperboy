<% is_first = vf.index.nil? || vf.index == 0 %>

<div class="form-group">
  <%= vf.label :year, "Year" %>
  <%= vf.select :year,
        options_for_select((1920..Date.today.year).to_a.reverse),
        { prompt: "Select Year" },
        class: "form-control",
        required: is_first,
        data: {
          nhtsa_vehicle_target: "year",
          action: "change->nhtsa-vehicle#yearChanged"
        } %>
</div>
<div class="form-group">
  <%= vf.label :make, "Make" %>
  <select data-nhtsa-vehicle-target="make"
          data-action="change->nhtsa-vehicle#makeChanged"
          class="form-control" disabled>
    <option value="">Select Make</option>
  </select>
  <%= vf.hidden_field :make, data: { nhtsa_vehicle_target: "hiddenMake" } %>
  <input type="text"
         placeholder="Enter Make"
         class="form-control mt-1"
         style="display: none;"
         data-nhtsa-vehicle-target="otherMake"
         data-action="input->nhtsa-vehicle#otherMakeTyped">
</div>
<div class="form-group">
  <%= vf.label :model, "Model" %>
  <select data-nhtsa-vehicle-target="model"
          data-action="change->nhtsa-vehicle#modelChanged"
          class="form-control" disabled>
    <option value="">Select Model</option>
  </select>
  <%= vf.hidden_field :model, data: { nhtsa_vehicle_target: "hiddenModel" } %>
  <input type="text"
         placeholder="Enter Model"
         class="form-control mt-1"
         style="display: none;"
         data-nhtsa-vehicle-target="otherModel"
         data-action="input->nhtsa-vehicle#otherModelTyped">
</div>
<div class="form-group">
  <%= vf.label :color, "Color" %>
  <%= vf.select :color,
        options_for_select(%w[White Black Silver Blue Red Green Yellow Gray Brown]),
        { prompt: "Select Color" },
        class: "form-control",
        required: is_first %>
</div>
<div class="form-group">
  <%= vf.label :license_plate, "License Plate" %>
  <%= vf.text_field :license_plate,
        placeholder: "License Plate",
        class: "form-control",
        required: is_first,
        maxlength: 7,
        pattern: "[A-Za-z0-9]{1,7}",
        title: "Up to 7 letters or numbers",
        style: "text-transform: uppercase;" %>
</div>
<div class="form-group">
  <%= vf.label :take_home, "Take Home Vehicle" %>
  <%= vf.select :take_home,
        options_for_select(['Yes', 'No'], vf.object.take_home),
        { prompt: "Select" },
        class: "form-control",
        required: is_first %>
</div>
<div class="form-group flex-fill" data-controller="choices">
  <%= vf.label :garaging_location, "Garaging Location" %>
  <%= vf.select :garaging_location,
        options_for_select(@building_options, vf.object.garaging_location),
        { prompt: "Select Garaging Location" },
        class: "form-control",
        data: {
          choices_target: "select",
          placeholder: "Select Garaging Location"
        } %>
</div>
<div class="form-group flex-fill" data-controller="secondary-location">
  <button type="button"
          class="add-secondary-location-btn"
          data-secondary-location-target="addBtn"
          data-action="secondary-location#show">+ Add secondary garaging location</button>

  <div data-secondary-location-target="field" style="display: none;">
    <div data-controller="choices">
      <%= vf.label :secondary_garaging_location, "Secondary Garaging Location" %>
<%# include_blank, not prompt: collapsing the field clears the selection back to
    this blank option, and prompt: would omit it once a value is saved. %>
      <%= vf.select :secondary_garaging_location,
            options_for_select(@building_options, vf.object.secondary_garaging_location),
            { include_blank: true },
            class: "form-control",
            data: {
              choices_target: "select",
              secondary_location_target: "select",
              placeholder: "Select Secondary Garaging Location"
            } %>
    </div>
    <button type="button"
            class="remove-secondary-location-btn"
            data-action="secondary-location#hide">− Remove secondary location</button>
  </div>
</div>
