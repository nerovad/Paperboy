<!-- Generated by Paperboy Form Builder -->
<div class="form-header">
  <h1>Edit Critical Information Reporting</h1>
</div>

<div class="form-wrapper" data-controller="form-navigation conditional-fields">
  <%= form_with model: @critical_information_reporting, local: true do |form| %>

<!-- Page 1: Employee Info -->
<div class="form-page">
  <h2>Employee Info</h2>
<div class="form-row d-flex flex-wrap">
  <div class="form-group flex-fill">
    <%= form.label :employee_id, "Employee ID" %>
    <%= form.text_field :employee_id,
          class: "form-control",
          readonly: true %>
  </div>

  <div class="form-group flex-fill">
    <%= form.label :name, "Name" %>
    <%= form.text_field :name,
          class: "form-control",
          readonly: true %>
  </div>

  <div class="form-group flex-fill">
    <%= form.label :phone, "Phone" %>
    <%= form.text_field :phone,
          class: "form-control",
          required: true,
          placeholder: "e.g. 555-555-5555",
          title: "Enter a 10-digit phone number like 555-555-5555",
          data: {
            controller: "phone",
            phone_target: "input",
            action: "input->phone#format paste->phone#format blur->phone#validate"
          },
          "aria-describedby": "phoneHelp phoneError",
          pattern: "\\d{3}-\\d{3}-\\d{4}",
          inputmode: "numeric",
          autocomplete: "tel" %>
    <small id="phoneHelp" class="help-text text-muted"></small>
    <div id="phoneError" data-phone-target="error" class="field-error" aria-live="polite"></div>
  </div>

  <div class="form-group flex-fill">
    <%= form.label :email, "Email" %>
    <%= form.text_field :email,
          class: "form-control",
          required: true %>
  </div>
</div>
      </div>

<!-- Page 2: Agency Info -->
<div class="form-page" style="display:none;">
  <h2>Agency Info</h2>
<div data-controller="gsabss-selects" class="form-row d-flex flex-wrap">
  <div class="form-group">
    <%= form.label :agency, "Agency" %>
    <%= form.select :agency,
          options_for_select(@agency_options, @critical_information_reporting.agency),
          {},
          class: "form-control",
          id: "agency-select",
          data: {
            gsabss_selects_target: "agency",
            action: "change->gsabss-selects#loadDivisions"
          } %>
  </div>

  <div class="form-group">
    <%= form.label :division, "Division" %>
    <%= form.select :division,
          options_for_select(@division_options, @critical_information_reporting.division),
          {},
          class: "form-control",
          id: "division-select",
          data: {
            gsabss_selects_target: "division",
            action: "change->gsabss-selects#loadDepartments"
          } %>
  </div>

  <div class="form-group">
    <%= form.label :department, "Department" %>
    <%= form.select :department,
          options_for_select(@department_options, @critical_information_reporting.department),
          {},
          class: "form-control",
          id: "department-select",
          data: {
            gsabss_selects_target: "department",
            action: "change->gsabss-selects#loadUnits"
          } %>
  </div>

  <div class="form-group">
    <%= form.label :unit, "Unit" %>
    <%= form.select :unit,
          options_for_select(@unit_options, @critical_information_reporting.unit),
          {},
          class: "form-control",
          id: "unit-select",
          data: { gsabss_selects_target: "unit" } %>
  </div>
</div>
      </div>

<!-- Page 3: Incident Info -->
<div class="form-page" style="display:none;">
  <h2>Incident Info</h2>
        <div class="form-row d-flex flex-wrap">
<!-- FIELD:incident_type START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :incident_type, "Incident Type" %>
            <%= form.select :incident_type,
                  options_for_select(['Approved Event Permit', 'CEO Interest', 'Elevator Outage (Entrapment)', 'Elevator Outage (No Entrapment)', 'Generator of Alarm Testing', 'HVAC', 'Natural Disaster', 'Planned Outage', 'Unplanned Outage', 'Safety Incident', 'Tree Removal'], @critical_information_reporting.incident_type),
                  { include_blank: "Select..." },
                  { class: "form-control", required: true } %>
          </div>
<!-- FIELD:incident_type END -->
<!-- FIELD:urgency START --><div class="form-group flex-fill<%= '' %>" data-answer-depends-on="incident_type" data-answer-mappings="{&quot;Approved Event Permit&quot;:&quot;Before it happens&quot;,&quot;CEO Interest&quot;:&quot;Earliest convenience&quot;,&quot;Elevator Outage (Entrapment)&quot;:&quot;Immediate&quot;,&quot;Elevator Outage (No Entrapment)&quot;:&quot;Immediate&quot;,&quot;Generator of Alarm Testing&quot;:&quot;Before it happens&quot;,&quot;HVAC&quot;:&quot;Earliest convenience&quot;,&quot;Natural Disaster&quot;:&quot;Immediate&quot;,&quot;Planned Outage&quot;:&quot;Earliest convenience&quot;,&quot;Unplanned Outage&quot;:&quot;Immediate&quot;,&quot;Safety Incident&quot;:&quot;Earliest convenience&quot;,&quot;Tree Removal&quot;:&quot;Before it happens&quot;}">
  <%= form.label :urgency, "Urgency of Reporting" %>
            <%= form.select :urgency,
                  options_for_select(['Immediate', 'Earliest convenience', 'Before it happens'], @critical_information_reporting.urgency),
                  { include_blank: "Select..." },
                  { class: "form-control", required: true } %>
          </div>
<!-- FIELD:urgency END -->
<!-- FIELD:location START --><div class="form-group flex-fill overflow-visible" data-controller="choices">
  <%= form.label :location, "Where: Location" %>
            <%= form.select :location,
                  options_for_select(@location_options, @critical_information_reporting.location),
                  { include_blank: "Select..." },
                  { class: "form-control", required: true,
                    data: { choices_target: "select", placeholder: "Search for a location..." } } %>
          </div>
<!-- FIELD:location END -->
<!-- FIELD:staff_involved START --><div class="form-group flex-fill<%= '' %>" data-controller="choices">
  <%= form.label :staff_involved, "Staff Involved" %>
            <%= form.select :staff_involved,
                  options_for_select(Employee.order(:Last_Name).map { |e| "#{e.last_name}, #{e.first_name}" }, @critical_information_reporting.staff_involved.to_s.split(/,(?! )/)),
                  { include_blank: false },
                  { class: "form-control", required: true, multiple: true, data: { choices_target: "select", placeholder: "Select options..." } } %>
          </div>
<!-- FIELD:staff_involved END -->
<!-- FIELD:incident_details START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :incident_details, "Incident Details" %>
            <%= form.text_area :incident_details, rows: 5, class: "form-control", required: true %>
          </div>
<!-- FIELD:incident_details END -->
<!-- FIELD:cause START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :cause, "Cause" %>
            <%= form.text_area :cause, rows: 5, class: "form-control", required: true %>
          </div>
<!-- FIELD:cause END -->
        </div>
      </div>

<!-- Page 4: Impact -->
<div class="form-page" style="display:none;">
  <h2>Impact</h2>
        <div class="form-row d-flex flex-wrap">
<!-- FIELD:impact START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :impact, "Impact" %>
            <%= form.select :impact,
                  options_for_select(['Low', 'Medium', 'High'], @critical_information_reporting.impact),
                  { include_blank: "Select..." },
                  { class: "form-control", required: true } %>
          </div>
<!-- FIELD:impact END -->
<!-- FIELD:impact_started START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :impact_started, "When: Impact Started" %>
            <%= form.datetime_local_field :impact_started, class: "form-control", required: true %>
          </div>
<!-- FIELD:impact_started END -->
<!-- FIELD:impacted_customers START --><div class="form-group flex-fill<%= '' %>" data-controller="choices">
  <%= form.label :impacted_customers, "Impacted Customers" %>
            <%= form.select :impacted_customers,
                  options_for_select(['Building', 'Agency', 'Employee'], @critical_information_reporting.impacted_customers.to_s.split(",")),
                  { include_blank: false },
                  { class: "form-control", multiple: true, data: { choices_target: "select", placeholder: "Select options...", conditional_trigger: 'impacted_customers' } } %>
          </div>
<!-- FIELD:impacted_customers END -->
<!-- FIELD:building START -->          <div class="conditional-field" data-depends-on="impacted_customers" data-show-values="[&quot;Building&quot;]" style="<%= (@critical_information_reporting.impacted_customers.to_s.split(",") & ["Building"]).any? ? '' : 'display: none;' %>">
<div class="form-group flex-fill<%= '' %>" data-controller="choices">
  <%= form.label :building, "Building" %>
            <%= form.select :building,
                  options_for_select(['HOA', 'JJC', 'Service Building', 'Other'], @critical_information_reporting.building.to_s.split(",")),
                  { include_blank: false },
                  { class: "form-control", multiple: true, data: { choices_target: "select", placeholder: "Select options...", conditional_trigger: 'building' } } %>
          </div>
          </div>
<!-- FIELD:building END -->
<!-- FIELD:other_building START -->          <div class="conditional-field" data-depends-on="building" data-show-values="[&quot;Other&quot;]" style="<%= (@critical_information_reporting.building.to_s.split(",") & ["Other"]).any? ? '' : 'display: none;' %>">
<div class="form-group flex-fill<%= '' %>">
  <%= form.label :other_building, "Other Building" %>
            <%= form.text_field :other_building, class: "form-control" %>
          </div>
          </div>
<!-- FIELD:other_building END -->
<!-- FIELD:impacted_agency START -->          <div class="conditional-field" data-depends-on="impacted_customers" data-show-values="[&quot;Agency&quot;]" style="<%= (@critical_information_reporting.impacted_customers.to_s.split(",") & ["Agency"]).any? ? '' : 'display: none;' %>">
<div class="form-group flex-fill<%= '' %>" data-controller="choices">
  <%= form.label :impacted_agency, "Agency" %>
            <%= form.select :impacted_agency,
                  options_for_select(Agency.order(:long_name).pluck(:long_name).uniq, @critical_information_reporting.impacted_agency.to_s.split(",")),
                  { include_blank: false },
                  { class: "form-control", multiple: true, data: { choices_target: "select", placeholder: "Select options..." } } %>
          </div>
          </div>
<!-- FIELD:impacted_agency END -->
<!-- FIELD:impacted_employee START -->          <div class="conditional-field" data-depends-on="impacted_customers" data-show-values="[&quot;Employee&quot;]" style="<%= (@critical_information_reporting.impacted_customers.to_s.split(",") & ["Employee"]).any? ? '' : 'display: none;' %>">
<div class="form-group flex-fill<%= '' %>" data-controller="choices">
  <%= form.label :impacted_employee, "Employee" %>
            <%= form.select :impacted_employee,
                  options_for_select(Employee.where(Agency: 'GSA').order(:Last_Name).map { |e| "#{e.last_name}, #{e.first_name}" }, @critical_information_reporting.impacted_employee.to_s.split(/,(?! )/)),
                  { include_blank: false },
                  { class: "form-control", multiple: true, data: { choices_target: "select", placeholder: "Select options..." } } %>
          </div>
          </div>
<!-- FIELD:impacted_employee END -->
        </div>
      </div>

<!-- Page 5: Outcome -->
<div class="form-page" style="display:none;">
  <h2>Outcome</h2>
        <div class="form-row d-flex flex-wrap">
<!-- FIELD:next_steps START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :next_steps, "Next Steps" %>
            <%= form.text_area :next_steps, rows: 3, class: "form-control", required: true %>
          </div>
<!-- FIELD:next_steps END -->
<!-- FIELD:media_photo_pdf_etc START --><div class="form-group flex-fill<%= '' %>" data-controller="file-preview" data-file-preview-max-value="10">
  <%= form.label :media_photo_pdf_etc, "Media (Photo, PDF, etc.)" %>
            <% if @critical_information_reporting.media_photo_pdf_etc.attached? %>
              <div class="existing-attachments">
                <small class="form-text text-muted">Currently attached:</small>
                <div class="file-preview-grid">
                  <% @critical_information_reporting.media_photo_pdf_etc.each do |attachment| %>
                    <div class="file-preview-item">
                      <% if attachment.content_type.start_with?('image/') %>
                        <%= image_tag rails_blob_path(attachment, disposition: 'inline'), class: 'file-preview-thumb' %>
                      <% else %>
                        <div class="file-preview-icon"><i class="fas fa-file-pdf"></i></div>
                      <% end %>
                      <span class="file-preview-name"><%= attachment.filename %></span>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
            <%= form.file_field :media_photo_pdf_etc, multiple: true, class: "form-control", direct_upload: true, accept: "image/jpeg,image/png,image/gif,application/pdf", data: { file_preview_target: "input", action: "change->file-preview#preview" } %>
            <small class="form-text text-muted">You can select files multiple times — up to 10 total. <span data-file-preview-target="count"></span></small>
            <div data-file-preview-target="preview" class="file-preview-grid"></div>
          </div>
<!-- FIELD:media_photo_pdf_etc END -->
        </div>
      </div>

    <!-- Navigation Buttons -->
    <div class="navigation-buttons d-flex justify-content-between">
      <div>
        <button type="button" id="prevBtn" data-action="click->form-navigation#prevPage" style="display:none;">Previous</button>
      </div>
      <div>
        <button type="button" id="nextBtn" data-action="click->form-navigation#nextPage">Next</button>
        <%= form.submit "Update", data: { form_navigation_target: "submitButton" }, style: "display:none;" %>
      </div>
    </div>

    <!-- Progress (5 steps) -->
    <div class="progress-wrapper">
      <div class="progress-bar-container">
        <div class="progress-bar" id="progressBar"></div>
      </div>
      <div class="progress-dots">
        <% 5.times do |index| %>
          <div class="dot <%= 'active' if index == 0 %>"></div>
        <% end %>
      </div>
    </div>

  <% end %>
</div>
