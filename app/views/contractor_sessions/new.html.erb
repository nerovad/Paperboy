<!-- app/views/contractor_sessions/new.html.erb -->
<div class="form-header">
  <h1>Contractor Sign In</h1>
</div>

<div class="form-wrapper">
  <p class="form-intro">
    Contractor accounts are provisioned by your administrator. Employees should
    sign in through the main Microsoft login instead.
  </p>

  <%= form_with url: contractor_login_path, method: :post, local: true do %>
    <div class="form-group">
      <%= label_tag :email, "Email" %>
      <%= email_field_tag :email, params[:email], required: true, autofocus: true,
            autocomplete: "username", class: "form-control" %>
    </div>

    <div class="form-group">
      <%= label_tag :password, "Password" %>
      <%= password_field_tag :password, nil, required: true,
            autocomplete: "current-password", class: "form-control" %>
    </div>

    <div class="form-actions">
      <%= submit_tag "Sign In", class: "btn approve" %>
      <%= link_to "Forgot password?", new_contractor_password_path, class: "btn" %>
    </div>
  <% end %>
</div>
