<!-- Generated by Paperboy Form Builder -->
<div class="form-header">
  <h1>Leave of Absence</h1>
</div>

<div class="form-wrapper" data-controller="form-navigation conditional-fields">
  <%= form_with model: @leave_of_absence_form, local: true do |form| %>

<!-- Page 1: Employee Info -->
<div class="form-page">
  <h2>Employee Info</h2>
<div class="form-row d-flex flex-wrap">
  <div class="form-group flex-fill">
    <%= form.label :employee_id, "Employee ID" %>
    <%= form.text_field :employee_id,
          value: @prefill_data[:employee_id],
          class: "form-control",
          readonly: true %>
  </div>

  <div class="form-group flex-fill">
    <%= form.label :name, "Name" %>
    <%= form.text_field :name,
          value: @prefill_data[:name],
          class: "form-control",
          readonly: true %>
  </div>

  <div class="form-group flex-fill">
    <%= form.label :phone, "Phone" %>
    <%= form.text_field :phone,
          value: @prefill_data[:phone],
          class: "form-control",
          required: true,
          placeholder: "e.g. 555-555-5555",
          title: "Enter a 10-digit phone number like 555-555-5555",
          data: {
            controller: "phone",
            phone_target: "input",
            action: "input->phone#format paste->phone#format blur->phone#validate"
          },
          "aria-describedby": "phoneHelp phoneError",
          pattern: "\\d{3}-\\d{3}-\\d{4}",
          inputmode: "numeric",
          autocomplete: "tel" %>
    <small id="phoneHelp" class="help-text text-muted"></small>
    <div id="phoneError" data-phone-target="error" class="field-error" aria-live="polite"></div>
  </div>

  <div class="form-group flex-fill">
    <%= form.label :email, "Email" %>
    <%= form.text_field :email,
          value: @prefill_data[:email],
          class: "form-control",
          required: true %>
  </div>
</div>
      </div>

<!-- Page 2: Agency Info -->
<div class="form-page" style="display:none;">
  <h2>Agency Info</h2>
<div data-controller="gsabss-selects" class="form-row d-flex flex-wrap">
  <div class="form-group">
    <%= form.label :agency, "Agency" %>
    <%= form.select :agency,
          options_for_select(@agency_options, @prefill_data[:agency]),
          {},
          class: "form-control",
          id: "agency-select",
          data: {
            gsabss_selects_target: "agency",
            action: "change->gsabss-selects#loadDivisions"
          } %>
  </div>

  <div class="form-group">
    <%= form.label :division, "Division" %>
    <%= form.select :division,
          options_for_select(@division_options, @prefill_data[:division]),
          {},
          class: "form-control",
          id: "division-select",
          data: {
            gsabss_selects_target: "division",
            action: "change->gsabss-selects#loadDepartments"
          } %>
  </div>

  <div class="form-group">
    <%= form.label :department, "Department" %>
    <%= form.select :department,
          options_for_select(@department_options, @prefill_data[:department]),
          {},
          class: "form-control",
          id: "department-select",
          data: {
            gsabss_selects_target: "department",
            action: "change->gsabss-selects#loadUnits"
          } %>
  </div>

  <div class="form-group">
    <%= form.label :unit, "Unit" %>
    <%= form.select :unit,
          options_for_select(@unit_options, @prefill_data[:unit]),
          {},
          class: "form-control",
          id: "unit-select",
          data: { gsabss_selects_target: "unit" } %>
  </div>
</div>
      </div>

<!-- Page 3: Leave Details -->
<div class="form-page" style="display:none;">
  <h2>Leave Details</h2>
        <div class="form-row d-flex flex-wrap">
<!-- FIELD:last_date_worked START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :last_date_worked, "Last Date Worked" %>
            <%= form.date_field :last_date_worked, class: "form-control", required: true %>
          </div>
<!-- FIELD:last_date_worked END -->
<!-- FIELD:leave_start_date START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :leave_start_date, "Leave Start Date" %>
            <%= form.date_field :leave_start_date, class: "form-control", required: true %>
          </div>
<!-- FIELD:leave_start_date END -->
<!-- FIELD:leave_end_date START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :leave_end_date, "Leave End Date" %>
            <%= form.date_field :leave_end_date, class: "form-control", required: true %>
          </div>
<!-- FIELD:leave_end_date END -->
<!-- FIELD:is_this_an_extension START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :is_this_an_extension, "Is this an extension?" %>
            <%= form.select :is_this_an_extension,
                  options_for_select(['Yes', 'No']),
                  { include_blank: "Select..." },
                  { class: "form-control", required: true } %>
          </div>
<!-- FIELD:is_this_an_extension END -->
<!-- FIELD:pay_status_during_leave START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :pay_status_during_leave, "Pay Status During Leave" %>
            <%= form.text_field :pay_status_during_leave, class: "form-control", required: true %>
          </div>
<!-- FIELD:pay_status_during_leave END -->
<!-- FIELD:type_of_leave START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :type_of_leave, "Type of Leave" %>
            <%= form.select :type_of_leave,
                  options_for_select(['FMLA', 'Personal', 'Disability']),
                  { include_blank: "Select..." },
                  { class: "form-control", required: true } %>
          </div>
<!-- FIELD:type_of_leave END -->
<!-- FIELD:reason_for_leave START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :reason_for_leave, "Reason for Leave" %>
            <%= form.select :reason_for_leave,
                  options_for_select(['Employee Health Condition', 'Disabled by Pregnancy or Childbirth', 'Care for Immediate Family Member', 'Bonding Leave', 'Military Service Leave', 'Emergency Rescue Personnel Leave', 'To assist a child spouse or parent who is a member of the National Guard or Reserves with a qualifying exigency related to active duty or a call of active duty status in support of a contingency operation', 'To care for a child spouse parent or next of kin service member of the United States Armed Forces with serious injury or illness incurred in the line of duty', 'Donor Leave', 'Personal Leave', 'Other']),
                  { include_blank: "Select..." },
                  { class: "form-control", required: true, data: { conditional_trigger: 'reason_for_leave' } } %>
          </div>
<!-- FIELD:reason_for_leave END -->
<!-- FIELD:work_related_injury START -->          <div class="conditional-field" data-depends-on="reason_for_leave" data-show-values="[&quot;Employee Health Condition&quot;]" style="display: none;">
<div class="form-group flex-fill<%= '' %>">
  <%= form.label :work_related_injury, "Work related Injury?" %>
            <%= form.select :work_related_injury,
                  options_for_select(['Yes', 'No']),
                  { include_blank: "Select..." },
                  { class: "form-control" } %>
          </div>
          </div>
<!-- FIELD:work_related_injury END -->
<!-- FIELD:injury_date START -->          <div class="conditional-field" data-depends-on="reason_for_leave" data-show-values="[&quot;Employee Health Condition&quot;]" style="display: none;">
<div class="form-group flex-fill<%= '' %>">
  <%= form.label :injury_date, "Injury Date" %>
            <%= form.date_field :injury_date, class: "form-control" %>
          </div>
          </div>
<!-- FIELD:injury_date END -->
<!-- FIELD:accomodations_upon_return_to_work START -->          <div class="conditional-field" data-depends-on="reason_for_leave" data-show-values="[&quot;Employee Health Condition&quot;]" style="display: none;">
<div class="form-group flex-fill<%= '' %>">
  <%= form.label :accomodations_upon_return_to_work, "Accomodations Upon Return to Work?" %>
            <%= form.select :accomodations_upon_return_to_work,
                  options_for_select(['Yes', 'No']),
                  { include_blank: "Select..." },
                  { class: "form-control" } %>
          </div>
          </div>
<!-- FIELD:accomodations_upon_return_to_work END -->
<!-- FIELD:doctors_note_attachment START -->          <div class="conditional-field" data-depends-on="reason_for_leave" data-show-values="[&quot;Employee Health Condition&quot;]" style="display: none;">
<div class="form-group flex-fill<%= '' %>" data-controller="file-preview" data-file-preview-max-value="10">
  <%= form.label :doctors_note_attachment, "Doctors Note Attachment" %>
            <%= form.file_field :doctors_note_attachment, multiple: true, class: "form-control", direct_upload: true, accept: "image/jpeg,image/png,image/gif,application/pdf", data: { file_preview_target: "input", action: "change->file-preview#preview" } %>
            <small class="form-text text-muted">You can select files multiple times — up to 10 total. <span data-file-preview-target="count"></span></small>
            <div data-file-preview-target="preview" class="file-preview-grid"></div>
          </div>
          </div>
<!-- FIELD:doctors_note_attachment END -->
<!-- FIELD:other_reason START -->          <div class="conditional-field" data-depends-on="reason_for_leave" data-show-values="[&quot;Other&quot;]" style="display: none;">
<div class="form-group flex-fill<%= '' %>">
  <%= form.label :other_reason, "Other Reason" %>
            <%= form.text_area :other_reason, rows: 5, class: "form-control" %>
          </div>
          </div>
<!-- FIELD:other_reason END -->
        </div>
      </div>

<!-- Page 4: Employee Declarations -->
<div class="form-page" style="display:none;">
  <h2>Employee Declarations</h2>
        <div class="form-row d-flex flex-wrap">
<!-- FIELD:are_you_applying_for_disability_benefits START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :are_you_applying_for_disability_benefits, "Are you applying for disability benefits?" %>
            <%= form.select :are_you_applying_for_disability_benefits,
                  options_for_select(['Yes', 'No']),
                  { include_blank: "Select..." },
                  { class: "form-control", required: true } %>
          </div>
<!-- FIELD:are_you_applying_for_disability_benefits END -->
<!-- FIELD:do_you_waive_benefits_from_any_sources START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :do_you_waive_benefits_from_any_sources, "Do you waive benefits from any sources?" %>
            <%= form.select :do_you_waive_benefits_from_any_sources,
                  options_for_select(['Yes', 'No']),
                  { include_blank: "Select..." },
                  { class: "form-control", required: true } %>
          </div>
<!-- FIELD:do_you_waive_benefits_from_any_sources END -->
<!-- FIELD:did_the_employee_confirm_this_request_via_email START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :did_the_employee_confirm_this_request_via_email, "Did the employee confirm this request via email?" %>
            <%= form.select :did_the_employee_confirm_this_request_via_email,
                  options_for_select(['Yes', 'No']),
                  { include_blank: "Select..." },
                  { class: "form-control", required: true } %>
          </div>
<!-- FIELD:did_the_employee_confirm_this_request_via_email END -->
<!-- FIELD:additional_notes_or_comments START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :additional_notes_or_comments, "Additional Notes or Comments" %>
            <%= form.text_area :additional_notes_or_comments, rows: 5, class: "form-control", required: true %>
          </div>
<!-- FIELD:additional_notes_or_comments END -->
        </div>
      </div>

    <!-- Navigation Buttons -->
    <div class="navigation-buttons d-flex justify-content-between">
      <div>
        <button type="button" id="prevBtn" data-action="click->form-navigation#prevPage" style="display:none;">Previous</button>
      </div>
      <div>
        <button type="button" id="nextBtn" data-action="click->form-navigation#nextPage">Next</button>
        <%= form.submit "Submit", data: { form_navigation_target: "submitButton" }, style: "display:none;" %>
      </div>
    </div>

    <!-- Progress (4 steps) -->
    <div class="progress-wrapper">
      <div class="progress-bar-container">
        <div class="progress-bar" id="progressBar"></div>
      </div>
      <div class="progress-dots">
        <% 4.times do |index| %>
          <div class="dot <%= 'active' if index == 0 %>"></div>
        <% end %>
      </div>
    </div>

  <% end %>
</div>
