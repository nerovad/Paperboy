<div class="form-header">
  <h1>Id Badge Request Form</h1>
</div>

<div class="form-wrapper">
  <div class="form-inner">

  <%= render partial: "shared/readonly_record",
             locals: { record: @id_badge_request_form,
                       exclude: %w[id created_at updated_at approver_id deny_reason] } %>

  <% # Display media attachments %>
  <% @id_badge_request_form.class.reflect_on_all_attachments.each do |attachment_ref| %>
    <% name = attachment_ref.name %>
    <% attachments = @id_badge_request_form.public_send(name) %>
    <% if attachments.respond_to?(:attached?) && attachments.attached? %>
      <div class="media-section">
        <h3><%= name.to_s.humanize %></h3>
        <div class="file-preview-grid">
          <% attachments.each do |attachment| %>
            <div class="file-preview-item">
              <% if attachment.content_type.start_with?('image/') %>
                <%= image_tag rails_blob_path(attachment, disposition: 'inline'), class: 'file-preview-thumb' %>
              <% else %>
                <div class="file-preview-icon"><i class="fas fa-file-pdf"></i></div>
              <% end %>
              <span class="file-preview-name"><%= attachment.filename %></span>
              <span class="file-preview-name text-muted"><%= number_to_human_size(attachment.byte_size) %></span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>

  <div class="form-actions" style="margin-top: 16px;">
    <%= link_to "Back to Inbox", inbox_queue_path, class: "form-btn" %>
    <%= link_to "Download PDF", pdf_id_badge_request_form_path(@id_badge_request_form), target: "_blank", class: "form-btn" %>
  </div>
  </div>
</div>
