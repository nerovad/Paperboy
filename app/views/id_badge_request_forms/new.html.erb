<!-- Generated by Paperboy Form Builder -->
<div class="form-header">
  <h1>ID Badge Request</h1>
</div>

<div class="form-wrapper" data-controller="form-navigation conditional-fields">
  <%= form_with model: @id_badge_request_form, local: true do |form| %>

<!-- Page 1: Employee Info -->
<div class="form-page">
  <h2>Employee Info</h2>
<div class="form-row d-flex flex-wrap">
  <div class="form-group flex-fill">
    <%= form.label :employee_id, "Employee ID" %>
    <%= form.text_field :employee_id,
          value: @prefill_data[:employee_id],
          class: "form-control",
          readonly: true %>
  </div>

  <div class="form-group flex-fill">
    <%= form.label :name, "Name" %>
    <%= form.text_field :name,
          value: @prefill_data[:name],
          class: "form-control",
          readonly: true %>
  </div>

  <div class="form-group flex-fill">
    <%= form.label :phone, "Phone" %>
    <%= form.text_field :phone,
          value: @prefill_data[:phone],
          class: "form-control",
          required: true,
          placeholder: "e.g. 555-555-5555",
          title: "Enter a 10-digit phone number like 555-555-5555",
          data: {
            controller: "phone",
            phone_target: "input",
            action: "input->phone#format paste->phone#format blur->phone#validate"
          },
          "aria-describedby": "phoneHelp phoneError",
          pattern: "\\d{3}-\\d{3}-\\d{4}",
          inputmode: "numeric",
          autocomplete: "tel" %>
    <small id="phoneHelp" class="help-text text-muted"></small>
    <div id="phoneError" data-phone-target="error" class="field-error" aria-live="polite"></div>
  </div>

  <div class="form-group flex-fill">
    <%= form.label :email, "Email" %>
    <%= form.text_field :email,
          value: @prefill_data[:email],
          class: "form-control",
          required: true %>
  </div>
</div>
      </div>

<!-- Page 2: Agency Info -->
<div class="form-page" style="display:none;">
  <h2>Agency Info</h2>
<div data-controller="gsabss-selects" class="form-row d-flex flex-wrap">
  <div class="form-group">
    <%= form.label :agency, "Agency" %>
    <%= form.select :agency,
          options_for_select(@agency_options, @prefill_data[:agency]),
          {},
          class: "form-control",
          id: "agency-select",
          data: {
            gsabss_selects_target: "agency",
            action: "change->gsabss-selects#loadDivisions"
          } %>
  </div>

  <div class="form-group">
    <%= form.label :division, "Division" %>
    <%= form.select :division,
          options_for_select(@division_options, @prefill_data[:division]),
          {},
          class: "form-control",
          id: "division-select",
          data: {
            gsabss_selects_target: "division",
            action: "change->gsabss-selects#loadDepartments"
          } %>
  </div>

  <div class="form-group">
    <%= form.label :department, "Department" %>
    <%= form.select :department,
          options_for_select(@department_options, @prefill_data[:department]),
          {},
          class: "form-control",
          id: "department-select",
          data: {
            gsabss_selects_target: "department",
            action: "change->gsabss-selects#loadUnits"
          } %>
  </div>

  <div class="form-group">
    <%= form.label :unit, "Unit" %>
    <%= form.select :unit,
          options_for_select(@unit_options, @prefill_data[:unit]),
          {},
          class: "form-control",
          id: "unit-select",
          data: { gsabss_selects_target: "unit" } %>
  </div>
</div>
      </div>

<!-- Page 3: Badge Type -->
<div class="form-page" style="display:none;">
  <h2>Badge Type</h2>
        <div class="form-row d-flex flex-wrap">
<!-- FIELD:badge_type START --><div class="form-group flex-fill<%= '' %>" data-controller="choices">
  <%= form.label :badge_type, "Badge Type" %>
            <%= form.select :badge_type,
                  options_for_select(['Regular Employee', 'Management', 'Contractor or Vendor', 'Grandy Jury', 'Extra - Help Employee', 'Intermittent Employee', 'Visitor', 'Volunteer', 'Department Provided Card']),
                  { include_blank: false },
                  { class: "form-control", required: true, multiple: true, data: { choices_target: "select", placeholder: "Select options...", conditional_trigger: 'badge_type' } } %>
          </div>
<!-- FIELD:badge_type END -->
<!-- FIELD:contractor_or_vendor_name START -->          <div class="conditional-field" data-depends-on="badge_type" data-show-values="[&quot;Contractor or Vendor&quot;]" style="display: none;">
<div class="form-group flex-fill<%= '' %>">
  <%= form.label :contractor_or_vendor_name, "Contractor or Vendor Name" %>
            <%= form.text_field :contractor_or_vendor_name, class: "form-control" %>
          </div>
          </div>
<!-- FIELD:contractor_or_vendor_name END -->
        </div>
      </div>

<!-- Page 4: Price List -->
<div class="form-page" style="display:none;">
  <h2>Price List</h2>
        <div class="form-row d-flex flex-wrap">
<!-- FIELD:services START --><div class="form-group flex-fill<%= '' %>" data-controller="choices">
  <%= form.label :services, "Services" %>
            <%= form.select :services,
                  options_for_select(['$20.00 Lamination/Photo/Clip on Provided Card', '$5.00 Lamination (Letter)', '$11.00 Employee ID Photo Extraction']),
                  { include_blank: false },
                  { class: "form-control", multiple: true, data: { choices_target: "select", placeholder: "Select options..." } } %>
          </div>
<!-- FIELD:services END -->
<!-- FIELD:badges START --><div class="form-group flex-fill<%= '' %>" data-controller="choices">
  <%= form.label :badges, "Badges" %>
            <%= form.select :badges,
                  options_for_select(['$5.00 ID Badge (No Access)', '$5.00 Renewal with Badge Provided', '$32.00 Reprinting due to Customer Error', '$68.31 Complete Badge with an Access Card', '$68.31 Replacement of Lost Badge with Access Card']),
                  { include_blank: false },
                  { class: "form-control", multiple: true, data: { choices_target: "select", placeholder: "Select options..." } } %>
          </div>
<!-- FIELD:badges END -->
<!-- FIELD:supplies START --><div class="form-group flex-fill<%= '' %>" data-controller="choices">
  <%= form.label :supplies, "Supplies" %>
            <%= form.select :supplies,
                  options_for_select(['$1.15 Clear Plastic Pouch', '$4.00 Nylon Sports Lanyard COV', '$12.25 Leather Badge Holder with Clip', '$3.50 Premier Retractable Badge Holder', '$4.50 Chrome Retracable Badge Holder', '$8.00 Extra Photo (on Plastic Car)', '$48.00 Background Check', '$16.00 Digital Key Fob', '$5.00 Blank Card', 'Other']),
                  { include_blank: false },
                  { class: "form-control", multiple: true, data: { choices_target: "select", placeholder: "Select options..." } } %>
          </div>
<!-- FIELD:supplies END -->
<!-- FIELD:total_charges START --><div class="form-group flex-fill<%= '' %>">
  <%= form.label :total_charges, "Total Charges" %>
            <%= form.number_field :total_charges, class: "form-control field-readonly", readonly: true %>
          </div>
<!-- FIELD:total_charges END -->
        </div>
      </div>

    <!-- Navigation Buttons -->
    <div class="navigation-buttons d-flex justify-content-between">
      <div>
        <button type="button" id="prevBtn" data-action="click->form-navigation#prevPage" style="display:none;">Previous</button>
      </div>
      <div>
        <button type="button" id="nextBtn" data-action="click->form-navigation#nextPage">Next</button>
        <%= form.submit "Submit", data: { form_navigation_target: "submitButton" }, style: "display:none;" %>
      </div>
    </div>

    <!-- Progress (4 steps) -->
    <div class="progress-wrapper">
      <div class="progress-bar-container">
        <div class="progress-bar" id="progressBar"></div>
      </div>
      <div class="progress-dots">
        <% 4.times do |index| %>
          <div class="dot <%= 'active' if index == 0 %>"></div>
        <% end %>
      </div>
    </div>

  <% end %>
</div>
