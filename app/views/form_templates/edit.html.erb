<%
  form_fields_for_conditions = @form_template.form_fields.ordered.map do |field|
    {
      id: field.id,
      label: field.label,
      field_name: field.field_name,
      field_type: field.field_type,
      dropdown_values: field.dropdown_values
    }
  end

  # [label, step_number] pairs for the "bind email to step" dropdown.
  routing_step_choices = @form_template.routing_steps.ordered.map do |s|
    ["Step #{s.step_number} — #{s.routing_label}", s.step_number]
  end
  # Email-type fields usable as a recipient address.
  email_field_choices = @form_template.form_fields.ordered
                          .select { |f| f.field_type == 'email' }
                          .map { |f| [f.label, f.field_name] }
  # Stable field names for the placeholder cheatsheet.
  email_token_field_names = @form_template.form_fields.ordered.map(&:field_name).compact
%>
<div class="edit-wizard-wrapper form-builder-modal"
     data-controller="form-builder"
     data-form-builder-acl-groups-value="<%= @acl_groups.to_json %>"
     data-form-builder-employees-value="<%= @employees.to_json %>"
     data-form-builder-form-fields-value="<%= form_fields_for_conditions.to_json %>"
     data-form-builder-routing-step-choices-value="<%= routing_step_choices.to_json %>"
     data-form-builder-email-field-choices-value="<%= email_field_choices.to_json %>"
     data-form-builder-predefined-statuses-value="<%= FormTemplateStatus::PREDEFINED_STATUSES.to_json %>"
     data-form-builder-valid-categories-value="<%= FormTemplateStatus::VALID_CATEGORIES.to_json %>"
     data-form-builder-edit-mode-value="true">
  <div class="form-builder-modal-content">
    <% if @form_template.errors.any? %>
      <div class="alert alert-danger" role="alert" style="background-color: #f8d7da; color: #721c24; padding: 15px; border-radius: 6px 6px 0 0; margin: 0;">
        <h4 style="margin-top: 0;">Please correct the following errors:</h4>
        <ul style="margin-bottom: 0;">
          <% @form_template.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @form_template,
                  url: form_template_path(@form_template),
                  method: :patch,
                  local: true,
                  data: {
                    form_builder_target: "form",
                    action: "submit->form-builder#submitEditForm"
                  } do |f| %>

      <div class="modal-header">
        <div>
          <h2>Edit: <%= @form_template.name %></h2>
          <span class="wizard-page-label" data-form-builder-target="wizardPageLabel"></span>
        </div>
        <%= link_to "← Back", form_template_path(@form_template), class: "close-modal", style: "text-decoration: none; font-size: 18px;" %>
      </div>

      <div class="modal-body">

        <!-- ========== Page 1: Basic Info ========== -->
        <div class="wizard-page" data-form-builder-target="wizardPage" data-wizard-title="Basic Info">
          <div class="form-group">
            <label>Name of Form
              <span style="margin-left: 10px; background: #6c757d; color: white; padding: 2px 8px; border-radius: 4px; font-size: 0.85em;">Locked</span>
            </label>
            <div class="form-control" style="background-color: #f5f5f5; cursor: not-allowed; color: #495057;">
              <%= @form_template.name %>
            </div>
            <small class="form-text" style="color: #6c757d;">
              Form name cannot be changed after creation because it determines the class name and database table.
            </small>
          </div>

          <div class="form-group">
            <label>Tags</label>
            <small class="form-text" style="display: block; margin-bottom: 8px; color: #6c757d;">
              Add tags to help users find this form. Press Enter or comma to add a tag.
            </small>
            <div class="tag-chips-container"
                 data-controller="tag-chips"
                 data-tag-chips-existing-tags-value="<%= @existing_tags.to_json %>"
                 data-tag-chips-tags-value="<%= @form_template.tags_array.to_json %>">
              <div class="tag-chips-input-wrapper">
                <div class="tag-chips" data-tag-chips-target="chips"></div>
                <input type="text"
                       class="tag-chips-input"
                       placeholder="Type to add tags..."
                       data-tag-chips-target="input"
                       data-action="keydown->tag-chips#handleKeydown input->tag-chips#handleInput blur->tag-chips#handleBlur">
                <div class="tag-autocomplete" data-tag-chips-target="autocomplete" style="display: none;"></div>
              </div>
              <%= f.hidden_field :tags, value: @form_template.tags, data: { tag_chips_target: "hiddenField" } %>
            </div>
          </div>

          <div class="form-group">
            <label for="form_visibility">Access Level <span class="required">*</span></label>
            <%= f.select :visibility,
                        options_for_select([
                          ['Public (accessible to all users)', 'public'],
                          ['Restricted (manage access in ACL)', 'restricted']
                        ], @form_template.visibility),
                        {},
                        {
                          id: "form_visibility",
                          class: "form-control"
                        } %>
            <small class="form-text" style="color: #6c757d;">
              Public forms are automatically granted to every organization and group.
              Restricted forms require access to be configured in the ACL page.
            </small>
          </div>

          <div class="form-group">
            <label for="form_reference_prefix">Reference Prefix</label>
            <%= f.text_field :reference_prefix,
                            id: "form_reference_prefix",
                            class: "form-control",
                            value: @form_template.reference_prefix,
                            maxlength: 10,
                            placeholder: "e.g. LOA",
                            style: "text-transform: uppercase;" %>
            <small class="form-text" style="color: #6c757d;">
              Fronts each submission's reference number (e.g. <code>LOA-1042</code>), used to search
              the inbox. Letters/numbers only, unique across forms. Auto-filled from the form name if left blank.
            </small>
          </div>

          <div class="form-group">
            <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
              <%= f.check_box :skip_code_generation %>
              This form has custom code (don't regenerate controller/views)
            </label>
            <small class="form-text" style="color: #6c757d;">
              For hand-coded forms (custom JS, APIs, bespoke controllers). The builder will still
              manage routing steps, statuses and email notifications, but will never overwrite this
              form's controller, views, or model.
            </small>
          </div>

        </div>

        <!-- ========== Page 2: Page Setup ========== -->
        <div class="wizard-page" data-form-builder-target="wizardPage" data-wizard-title="Page Setup" style="display: none;">
          <div class="form-group">
            <label for="form_page_count">Number of Pages <span class="required">*</span></label>
            <%= f.number_field :page_count,
                              id: "form_page_count",
                              class: "form-control",
                              min: 2,
                              max: 30,
                              value: @form_template.page_count,
                              data: {
                                form_builder_target: "pageCount",
                                action: "change->form-builder#updatePageHeaders"
                              } %>
            <small class="form-text" style="color: #856404; background-color: #fff3cd; padding: 8px; border-radius: 4px; margin-top: 5px; display: block;">
              Warning: Reducing page count will fail if fields exist on higher pages. Remove those fields first.
            </small>
          </div>

          <div class="form-group page-headers-container"
               data-form-builder-target="pageHeadersContainer"
               style="<%= 'display: none;' if @form_template.page_count <= 2 %>">
            <label>Page Names (for pages 3+)</label>
            <div data-form-builder-target="pageHeadersList">
              <% (@form_template.page_count - 2).times do |i| %>
                <div class="form-group" style="margin-bottom: 10px;">
                  <label style="font-size: 0.9em; color: #6c757d;">Page <%= i + 3 %> Header</label>
                  <%= text_field_tag "form_template[page_headers][]",
                                    @form_template.page_headers&.dig(i),
                                    class: "form-control form-control-sm",
                                    placeholder: "e.g., Additional Information",
                                    data: { action: "input->form-builder#refreshPageSelects" } %>
                </div>
              <% end %>
            </div>
          </div>
        </div>

        <!-- ========== Page 3: Routing ========== -->
        <div class="wizard-page" data-form-builder-target="wizardPage" data-wizard-title="Routing" style="display: none;">
          <div class="alert alert-warning" role="alert" style="background-color: #fff3cd; color: #856404; padding: 15px; border-radius: 6px; margin-bottom: 20px;">
            <strong>Warning:</strong> Changing submission routing options will regenerate the controller file,
            overwriting any manual customizations.
          </div>

          <div class="form-group">
            <label for="form_submission_type">Form Submission Routing <span class="required">*</span></label>
            <%= f.select :submission_type,
                        options_for_select([
                          ['Submit to Database (Ends the workflow)', 'database'],
                          ['Routed for Approval', 'approval']
                        ], @form_template.submission_type),
                        {},
                        {
                          id: "form_submission_type",
                          class: "form-control",
                          data: {
                            form_builder_target: "submissionType",
                            action: "change->form-builder#toggleApprovalRouting"
                          }
                        } %>
          </div>

          <div class="form-group"
               data-form-builder-target="approvalRoutingContainer"
               style="<%= 'display: none;' unless @form_template.requires_approval? %>">
            <label>Routing Steps <span class="required">*</span></label>
            <small class="form-text" style="display: block; margin-bottom: 10px;">
              Add one or more routing steps. Forms will be routed through each step in order.
            </small>
            <div class="routing-steps-container" data-form-builder-target="routingStepsContainer">
              <% if @form_template.routing_steps.any? %>
                <% @form_template.routing_steps.ordered.each_with_index do |step, index| %>
                  <div class="routing-step-item" data-form-builder-target="routingStepItem" style="background: #f0f4f8; padding: 12px; margin-bottom: 10px; border-radius: 6px; border-left: 3px solid #007bff;">
                    <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
                      <div class="routing-step-drag-handle" title="Drag to reorder" style="display: flex; flex-direction: column; align-items: center; justify-content: center; cursor: grab; padding: 6px 10px; background: #dde6f1; border-radius: 4px; min-width: 60px;">
                        <span class="step-number" style="font-size: 12px; font-weight: 700; color: #495057;">Step <%= index + 1 %></span>
                        <span style="font-size: 14px; color: #6c757d;">&#x2630;</span>
                      </div>

                      <div style="flex: 1; min-width: 150px;">
                        <select name="routing_steps[][routing_type]"
                                class="form-control form-control-sm routing-type-select"
                                data-action="change->form-builder#toggleStepEmployeeSelect"
                                required>
                          <option value="">Select...</option>
                          <option value="supervisor" <%= 'selected' if step.routing_type == 'supervisor' %>>Supervisor</option>
                          <option value="department_head" <%= 'selected' if step.routing_type == 'department_head' %>>Department Head</option>
                          <option value="employee" <%= 'selected' if step.routing_type == 'employee' %>>Specific Employee</option>
                          <option value="group" <%= 'selected' if step.routing_type == 'group' %>>Group</option>
                          <option value="authorization" <%= 'selected' if step.routing_type == 'authorization' %>>Authorization Console</option>
                        </select>
                      </div>

                      <div class="step-authorization-select" style="flex: 1; min-width: 220px; <%= 'display: none;' unless step.routing_type == 'authorization' %>">
                        <select name="routing_steps[][authorization_service_type]"
                                class="form-control form-control-sm step-authorization-dropdown"
                                data-action="change->form-builder#updateStepDisplayName"
                                title="Route to whoever holds this authorization for the submitter's budget unit">
                          <option value="">Select authorization…</option>
                          <% AuthorizedApprover::SERVICE_TYPES.each do |code, label| %>
                            <option value="<%= code %>" <%= 'selected' if step.authorization_service_type == code %>><%= label %></option>
                          <% end %>
                        </select>
                      </div>

                      <div class="step-employee-select" style="flex: 1; min-width: 200px; <%= 'display: none;' unless step.routing_type == 'employee' %>">
                        <select name="routing_steps[][employee_id]"
                                class="form-control form-control-sm step-employee-dropdown"
                                data-action="change->form-builder#updateStepDisplayName">
                          <option value="">Select employee...</option>
                          <% @employees.each do |emp| %>
                            <option value="<%= emp[1] %>" <%= 'selected' if step.employee_id == emp[1] %>><%= emp[0] %></option>
                          <% end %>
                        </select>
                      </div>

                      <div class="step-group-select" style="flex: 1; min-width: 200px; <%= 'display: none;' unless step.routing_type == 'group' %>">
                        <select name="routing_steps[][group_id]"
                                class="form-control form-control-sm step-group-dropdown"
                                data-action="change->form-builder#updateStepDisplayName">
                          <option value="">Select group...</option>
                          <% @acl_groups.each do |grp| %>
                            <option value="<%= grp[1] %>" <%= 'selected' if step.group_id == grp[1] %>><%= grp[0] %></option>
                          <% end %>
                        </select>
                      </div>

                      <div class="step-org-filter-select" style="flex: 1; min-width: 200px; <%= 'display: none;' unless step.routing_type == 'group' %>">
                        <select name="routing_steps[][org_filter_level]"
                                class="form-control form-control-sm step-org-filter-dropdown"
                                data-action="change->form-builder#updateStepDisplayName"
                                title="Restrict group members to those matching the submitter at this org level">
                          <option value="">Filter by submitter's…</option>
                          <% FormTemplateRoutingStep::ORG_FILTER_LEVELS.each do |lvl| %>
                            <option value="<%= lvl %>" <%= 'selected' if step.org_filter_level == lvl %>>Filter by submitter's <%= FormTemplateRoutingStep::ORG_FILTER_LABELS[lvl] %></option>
                          <% end %>
                        </select>
                      </div>

                      <div class="step-display-name" style="flex: 1; min-width: 180px;">
                        <input type="text" name="routing_steps[][display_name]"
                               class="form-control form-control-sm step-display-name-input"
                               value="<%= step.display_name %>"
                               placeholder="<%= step.default_pending_display_name %>">
                      </div>

                      <input type="hidden" name="routing_steps[][step_number]" class="step-number-input" value="<%= index + 1 %>">

                      <button type="button"
                              class="btn btn-danger btn-sm"
                              data-action="click->form-builder#removeRoutingStep"
                              style="padding: 4px 8px;">
                        Remove
                      </button>
                    </div>

                    <div class="step-condition-row" style="margin-top: 8px; padding: 8px; background: #fff; border-radius: 4px; border-left: 2px solid #6c757d;">
                      <div style="display: flex; gap: 8px; align-items: center; flex-wrap: wrap;">
                        <label style="margin: 0; font-size: 0.85em; color: #495057; display: flex; align-items: center; gap: 4px;">
                          <input type="checkbox"
                                 class="step-condition-toggle"
                                 data-action="change->form-builder#toggleStepCondition"
                                 <%= 'checked' if step.conditional? %>>
                          Only run this step if
                        </label>

                        <select name="routing_steps[][condition_field_name]"
                                class="form-control form-control-sm step-condition-field"
                                data-action="change->form-builder#updateStepConditionValue"
                                style="width: auto; min-width: 160px; <%= 'display: none;' unless step.conditional? %>"
                                data-selected-name="<%= step.condition_field_name %>">
                          <option value="">Select field...</option>
                        </select>

                        <select name="routing_steps[][condition_operator]"
                                class="form-control form-control-sm step-condition-operator"
                                style="width: auto; <%= 'display: none;' unless step.conditional? %>">
                          <option value="equals" <%= 'selected' if step.condition_operator == 'equals' %>>equals</option>
                          <option value="not_equals" <%= 'selected' if step.condition_operator == 'not_equals' %>>does not equal</option>
                        </select>

                        <span class="step-condition-value-wrapper" style="<%= 'display: none;' unless step.conditional? %>"
                              data-selected-value="<%= step.condition_value %>">
                          <input type="text"
                                 name="routing_steps[][condition_value]"
                                 class="form-control form-control-sm step-condition-value"
                                 value="<%= step.condition_value %>"
                                 placeholder="value">
                        </span>
                      </div>
                    </div>

                    <div class="step-inbox-buttons-row" style="margin-top: 8px; padding: 8px; background: #fff; border-radius: 4px; border-left: 2px solid #007bff;">
                      <div style="font-size: 0.85em; color: #495057; font-weight: 600; margin-bottom: 6px;">Inbox queue buttons at this step</div>
                      <div class="step-inbox-buttons-grid" style="display: flex; flex-wrap: wrap; gap: 8px;">
                        <% FormTemplate::INBOX_BUTTON_TYPES.each do |key, config| %>
                          <label style="flex: 0 0 calc(50% - 8px); display: flex; align-items: flex-start; gap: 6px; margin: 0; font-size: 0.85em; cursor: pointer;">
                            <input type="checkbox"
                                   name="routing_steps[][inbox_buttons][]"
                                   value="<%= key %>"
                                   class="step-inbox-button-checkbox"
                                   style="margin-top: 3px;"
                                   <%= 'checked' if step.inbox_button?(key) %>>
                            <span>
                              <strong><%= config[:label] %></strong>
                              <small style="display: block; color: #6c757d; font-weight: normal;"><%= config[:description] %></small>
                            </span>
                          </label>
                        <% end %>
                      </div>
                      <div class="step-button-labels" style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 8px;">
                        <label style="flex: 1; min-width: 140px; font-size: 0.85em; color: #495057;">
                          Approve button label
                          <input type="text"
                                 name="routing_steps[][approve_button_label]"
                                 class="form-control form-control-sm step-approve-button-label"
                                 placeholder="Approve"
                                 value="<%= step.approve_button_label %>">
                          <small style="display: block; color: #6c757d;">Optional — e.g. "Permit Printed". Still advances the workflow.</small>
                        </label>
                        <label style="flex: 1; min-width: 140px; font-size: 0.85em; color: #495057;">
                          Deny button label
                          <input type="text"
                                 name="routing_steps[][deny_button_label]"
                                 class="form-control form-control-sm step-deny-button-label"
                                 placeholder="Deny"
                                 value="<%= step.deny_button_label %>">
                          <small style="display: block; color: #6c757d;">Optional. Leave blank for the default "Deny".</small>
                        </label>
                      </div>
                    </div>
                  </div>
                <% end %>
              <% elsif @form_template.approval_routing_to.present? %>
                <!-- Convert legacy single routing to step format -->
                <div class="routing-step-item" data-form-builder-target="routingStepItem" style="background: #f0f4f8; padding: 12px; margin-bottom: 10px; border-radius: 6px; border-left: 3px solid #007bff;">
                  <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
                    <div class="routing-step-drag-handle" title="Drag to reorder" style="display: flex; flex-direction: column; align-items: center; justify-content: center; cursor: grab; padding: 6px 10px; background: #dde6f1; border-radius: 4px; min-width: 60px;">
                      <span class="step-number" style="font-size: 12px; font-weight: 700; color: #495057;">Step 1</span>
                      <span style="font-size: 14px; color: #6c757d;">&#x2630;</span>
                    </div>

                    <div style="flex: 1; min-width: 150px;">
                      <select name="routing_steps[][routing_type]"
                              class="form-control form-control-sm routing-type-select"
                              data-action="change->form-builder#toggleStepEmployeeSelect"
                              required>
                        <option value="">Select...</option>
                        <option value="supervisor" <%= 'selected' if @form_template.approval_routing_to == 'supervisor' %>>Supervisor</option>
                        <option value="department_head" <%= 'selected' if @form_template.approval_routing_to == 'department_head' %>>Department Head</option>
                        <option value="employee" <%= 'selected' if @form_template.approval_routing_to == 'employee' %>>Specific Employee</option>
                        <option value="group">Group</option>
                        <option value="authorization">Authorization Console</option>
                      </select>
                    </div>

                    <div class="step-employee-select" style="flex: 1; min-width: 200px; <%= 'display: none;' unless @form_template.approval_routing_to == 'employee' %>">
                      <select name="routing_steps[][employee_id]"
                              class="form-control form-control-sm step-employee-dropdown">
                        <option value="">Select employee...</option>
                        <% @employees.each do |emp| %>
                          <option value="<%= emp[1] %>" <%= 'selected' if @form_template.approval_employee_id == emp[1] %>><%= emp[0] %></option>
                        <% end %>
                      </select>
                    </div>

                    <div class="step-group-select" style="flex: 1; min-width: 200px; display: none;">
                      <select name="routing_steps[][group_id]"
                              class="form-control form-control-sm step-group-dropdown">
                        <option value="">Select group...</option>
                        <% @acl_groups.each do |grp| %>
                          <option value="<%= grp[1] %>"><%= grp[0] %></option>
                        <% end %>
                      </select>
                    </div>

                    <div class="step-authorization-select" style="flex: 1; min-width: 220px; display: none;">
                      <select name="routing_steps[][authorization_service_type]"
                              class="form-control form-control-sm step-authorization-dropdown"
                              title="Route to whoever holds this authorization for the submitter's budget unit">
                        <option value="">Select authorization…</option>
                        <% AuthorizedApprover::SERVICE_TYPES.each do |code, label| %>
                          <option value="<%= code %>"><%= label %></option>
                        <% end %>
                      </select>
                    </div>

                    <div class="step-org-filter-select" style="flex: 1; min-width: 200px; display: none;">
                      <select name="routing_steps[][org_filter_level]"
                              class="form-control form-control-sm step-org-filter-dropdown"
                              title="Restrict group members to those matching the submitter at this org level">
                        <option value="">Filter by submitter's…</option>
                        <% FormTemplateRoutingStep::ORG_FILTER_LEVELS.each do |lvl| %>
                          <option value="<%= lvl %>">Filter by submitter's <%= FormTemplateRoutingStep::ORG_FILTER_LABELS[lvl] %></option>
                        <% end %>
                      </select>
                    </div>

                    <input type="hidden" name="routing_steps[][step_number]" class="step-number-input" value="1">

                    <button type="button"
                            class="btn btn-danger btn-sm"
                            data-action="click->form-builder#removeRoutingStep"
                            style="padding: 4px 8px;">
                      Remove
                    </button>
                  </div>

                  <div class="step-inbox-buttons-row" style="margin-top: 8px; padding: 8px; background: #fff; border-radius: 4px; border-left: 2px solid #007bff;">
                    <div style="font-size: 0.85em; color: #495057; font-weight: 600; margin-bottom: 6px;">Inbox queue buttons at this step</div>
                    <div class="step-inbox-buttons-grid" style="display: flex; flex-wrap: wrap; gap: 8px;">
                      <% FormTemplate::INBOX_BUTTON_TYPES.each do |key, config| %>
                        <label style="flex: 0 0 calc(50% - 8px); display: flex; align-items: flex-start; gap: 6px; margin: 0; font-size: 0.85em; cursor: pointer;">
                          <input type="checkbox"
                                 name="routing_steps[][inbox_buttons][]"
                                 value="<%= key %>"
                                 class="step-inbox-button-checkbox"
                                 style="margin-top: 3px;"
                                 <%= 'checked' if @form_template.inbox_button?(key) %>>
                          <span>
                            <strong><%= config[:label] %></strong>
                            <small style="display: block; color: #6c757d; font-weight: normal;"><%= config[:description] %></small>
                          </span>
                        </label>
                      <% end %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
            <button type="button"
                    class="btn btn-secondary btn-sm"
                    data-action="click->form-builder#addRoutingStep"
                    style="margin-top: 10px;">
              + Add Routing Step
            </button>

          </div>

          <div class="form-group"
               data-form-builder-target="copyRecipientsContainer"
               style="<%= 'display: none;' unless @form_template.requires_approval? %>; margin-top: 24px;">
            <label>Send a Copy To</label>
            <small class="form-text" style="display: block; margin-bottom: 10px;">
              Recipients added here receive a read-only inbox row but are <strong>not</strong> part of the approval workflow.
            </small>

            <div class="copy-recipients-list" data-form-builder-target="copyRecipientsList">
              <% @form_template.copy_recipients.ordered.each do |recipient| %>
                <div class="copy-recipient-item" data-form-builder-target="copyRecipientItem" style="background: #f0f4f8; padding: 10px; margin-bottom: 8px; border-radius: 6px; border-left: 3px solid #6c757d;">
                  <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
                    <div style="flex: 0 0 150px;">
                      <select name="copy_recipients[][recipient_type]"
                              class="form-control form-control-sm copy-recipient-type"
                              data-action="change->form-builder#toggleCopyRecipientTarget"
                              required>
                        <option value="">Type…</option>
                        <option value="employee" <%= 'selected' if recipient.recipient_type == 'employee' %>>Specific Employee</option>
                        <option value="group" <%= 'selected' if recipient.recipient_type == 'group' %>>Group</option>
                        <option value="supervisor" <%= 'selected' if recipient.recipient_type == 'supervisor' %>>Submitter's Supervisor</option>
                      </select>
                    </div>

                    <div class="copy-recipient-employee" style="flex: 1; min-width: 200px; <%= 'display: none;' unless recipient.recipient_type == 'employee' %>">
                      <select name="copy_recipients[][employee_id]"
                              class="form-control form-control-sm copy-recipient-employee-select">
                        <option value="">Select employee...</option>
                        <% @employees.each do |emp| %>
                          <option value="<%= emp[1] %>" <%= 'selected' if recipient.employee_id == emp[1] %>><%= emp[0] %></option>
                        <% end %>
                      </select>
                    </div>

                    <div class="copy-recipient-group" style="flex: 1; min-width: 200px; <%= 'display: none;' unless recipient.recipient_type == 'group' %>">
                      <select name="copy_recipients[][group_id]"
                              class="form-control form-control-sm copy-recipient-group-select">
                        <option value="">Select group...</option>
                        <% @acl_groups.each do |grp| %>
                          <option value="<%= grp[1] %>" <%= 'selected' if recipient.group_id == grp[1] %>><%= grp[0] %></option>
                        <% end %>
                      </select>
                    </div>

                    <div style="flex: 0 0 180px;">
                      <select name="copy_recipients[][trigger_event]"
                              class="form-control form-control-sm copy-recipient-trigger"
                              required>
                        <option value="submit" <%= 'selected' if recipient.trigger_event == 'submit' %>>On submission</option>
                        <option value="approval" <%= 'selected' if recipient.trigger_event == 'approval' %>>On final approval</option>
                        <option value="either" <%= 'selected' if recipient.trigger_event == 'either' %>>On either</option>
                      </select>
                    </div>

                    <button type="button"
                            class="btn btn-danger btn-sm"
                            data-action="click->form-builder#removeCopyRecipient"
                            style="padding: 4px 8px;">
                      Remove
                    </button>
                  </div>
                </div>
              <% end %>
            </div>

            <button type="button"
                    class="btn btn-secondary btn-sm"
                    data-action="click->form-builder#addCopyRecipient"
                    style="margin-top: 8px;">
              + Add Copy Recipient
            </button>
          </div>

          <div class="form-group"
               data-form-builder-target="emailStepsContainer"
               style="margin-top: 24px;">
            <label>Email Notifications</label>
            <small class="form-text" style="display: block; margin-bottom: 10px;">
              Send a templated email when the form is submitted, or when a routing step (or the
              whole form) is approved or denied. Each email can attach the generated PDF and/or any
              media attached to the form. Use placeholders like
              <code>{{submitter_name}}</code>, <code>{{form_name}}</code>,
              <code>{{status_label}}</code>, <code>{{deny_reason}}</code> and
              <code>{{field.your_field_name}}</code> in the subject and body.
              <% if email_token_field_names.any? %>
                <br>Field tokens: <%= email_token_field_names.map { |n| "{{field.#{n}}}" }.join(", ") %>
              <% end %>
            </small>

            <div class="email-steps-list" data-form-builder-target="emailStepsList">
              <% @form_template.email_steps.ordered.each do |estep| %>
                <div class="email-step-item" data-form-builder-target="emailStepItem" style="background: #f0f4f8; padding: 12px; margin-bottom: 10px; border-radius: 6px; border-left: 3px solid #17a2b8;">
                  <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
                    <div style="flex: 0 0 160px;">
                      <select name="email_steps[][trigger_event]"
                              class="form-control form-control-sm email-step-trigger"
                              data-action="change->form-builder#toggleEmailTriggerStep"
                              required>
                        <option value="submit" <%= 'selected' if estep.trigger_event == 'submit' %>>On submission</option>
                        <option value="approved" <%= 'selected' if estep.trigger_event == 'approved' %>>On approval</option>
                        <option value="denied" <%= 'selected' if estep.trigger_event == 'denied' %>>On denial</option>
                      </select>
                    </div>

                    <div class="email-step-routing-step" style="flex: 0 0 200px; <%= 'display: none;' unless %w[approved denied].include?(estep.trigger_event) %>">
                      <select name="email_steps[][routing_step_number]"
                              class="form-control form-control-sm email-step-routing-step-select">
                        <option value="">Final outcome</option>
                        <% routing_step_choices.each do |label, num| %>
                          <option value="<%= num %>" <%= 'selected' if estep.routing_step_number == num %>><%= label %></option>
                        <% end %>
                      </select>
                    </div>

                    <div style="flex: 0 0 160px;">
                      <select name="email_steps[][recipient_type]"
                              class="form-control form-control-sm email-step-recipient-type"
                              data-action="change->form-builder#toggleEmailRecipientFields"
                              required>
                        <option value="">Recipient…</option>
                        <option value="submitter" <%= 'selected' if estep.recipient_type == 'submitter' %>>Submitter</option>
                        <option value="employee" <%= 'selected' if estep.recipient_type == 'employee' %>>Specific Employee</option>
                        <option value="group" <%= 'selected' if estep.recipient_type == 'group' %>>Group</option>
                        <option value="custom_email" <%= 'selected' if estep.recipient_type == 'custom_email' %>>Custom Email</option>
                        <option value="form_field" <%= 'selected' if estep.recipient_type == 'form_field' %>>Email Field on Form</option>
                      </select>
                    </div>

                    <div class="email-step-employee" style="flex: 1; min-width: 200px; <%= 'display: none;' unless estep.recipient_type == 'employee' %>">
                      <select name="email_steps[][employee_id]" class="form-control form-control-sm email-step-employee-select">
                        <option value="">Select employee...</option>
                        <% @employees.each do |emp| %>
                          <option value="<%= emp[1] %>" <%= 'selected' if estep.employee_id == emp[1] %>><%= emp[0] %></option>
                        <% end %>
                      </select>
                    </div>

                    <div class="email-step-group" style="flex: 1; min-width: 200px; <%= 'display: none;' unless estep.recipient_type == 'group' %>">
                      <select name="email_steps[][group_id]" class="form-control form-control-sm email-step-group-select">
                        <option value="">Select group...</option>
                        <% @acl_groups.each do |grp| %>
                          <option value="<%= grp[1] %>" <%= 'selected' if estep.group_id == grp[1] %>><%= grp[0] %></option>
                        <% end %>
                      </select>
                    </div>

                    <div class="email-step-custom" style="flex: 1; min-width: 200px; <%= 'display: none;' unless estep.recipient_type == 'custom_email' %>">
                      <input type="text" name="email_steps[][custom_email]"
                             class="form-control form-control-sm email-step-custom-input"
                             value="<%= estep.custom_email %>"
                             placeholder="name@venturacounty.gov">
                    </div>

                    <div class="email-step-field" style="flex: 1; min-width: 200px; <%= 'display: none;' unless estep.recipient_type == 'form_field' %>">
                      <select name="email_steps[][recipient_field_name]" class="form-control form-control-sm email-step-field-select">
                        <option value="">Select email field...</option>
                        <% email_field_choices.each do |label, fname| %>
                          <option value="<%= fname %>" <%= 'selected' if estep.recipient_field_name == fname %>><%= label %></option>
                        <% end %>
                      </select>
                    </div>

                    <button type="button"
                            class="btn btn-danger btn-sm"
                            data-action="click->form-builder#removeEmailStep"
                            style="padding: 4px 8px;">
                      Remove
                    </button>
                  </div>

                  <div style="margin-top: 8px;">
                    <input type="text" name="email_steps[][subject]"
                           class="form-control form-control-sm email-step-subject"
                           value="<%= estep.subject %>"
                           placeholder="Subject (supports {{tokens}})">
                  </div>

                  <div style="margin-top: 8px;">
                    <textarea name="email_steps[][body]"
                              class="form-control form-control-sm email-step-body"
                              rows="4"
                              placeholder="Email body (supports {{tokens}})"><%= estep.body %></textarea>
                  </div>

                  <div style="margin-top: 8px; display: flex; gap: 16px; flex-wrap: wrap;">
                    <label style="margin: 0; font-size: 0.85em; display: flex; align-items: center; gap: 6px; cursor: pointer;">
                      <input type="checkbox" name="email_steps[][attach_pdf]" value="1" class="email-step-attach-pdf" <%= 'checked' if estep.attach_pdf %>>
                      Attach form PDF
                    </label>
                    <label style="margin: 0; font-size: 0.85em; display: flex; align-items: center; gap: 6px; cursor: pointer;">
                      <input type="checkbox" name="email_steps[][attach_media]" value="1" class="email-step-attach-media" <%= 'checked' if estep.attach_media %>>
                      Attach media attachments
                    </label>
                  </div>
                </div>
              <% end %>
            </div>

            <button type="button"
                    class="btn btn-secondary btn-sm"
                    data-action="click->form-builder#addEmailStep"
                    style="margin-top: 8px;">
              + Add Email Notification
            </button>
          </div>
        </div>

        <!-- ========== Page 4: Statuses ========== -->
        <div class="wizard-page" data-form-builder-target="wizardPage" data-wizard-title="Statuses" style="display: none;">
          <div class="form-group" data-form-builder-target="statusConfigSection">
            <label>Status Configuration</label>

            <div data-form-builder-target="statusAutoMessage" style="<%= 'display: none;' unless @form_template.requires_approval? %>; padding: 12px; background: #e8f4f8; border-radius: 6px; color: #0c5460;">
              Statuses are auto-generated from your routing steps (e.g. "Sent to Supervisor", "Approved", "Denied"). You can add extra statuses below if needed.
            </div>

            <div data-form-builder-target="statusManualConfig" style="<%= 'display: none;' if @form_template.requires_approval? %>">
              <small class="form-text" style="display: block; margin-bottom: 10px; color: #6c757d;">
                Configure the statuses available for this form. Choose from predefined statuses or add custom ones.
              </small>
              <div class="statuses-container" data-form-builder-target="statusesContainer">
                <% if @form_template.statuses.user_configured.any? %>
                  <% @form_template.statuses.user_configured.ordered.each_with_index do |status, index| %>
                    <% if status.predefined? %>
                      <div class="status-item" data-form-builder-target="statusItem" style="background: #f8f9fa; padding: 10px 12px; margin-bottom: 8px; border-radius: 6px; border-left: 3px solid #28a745;">
                        <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
                          <span class="status-position" style="font-weight: bold; color: #6c757d; min-width: 30px;">#<%= index + 1 %></span>

                          <div class="status-name-display" style="flex: 1; min-width: 120px;">
                            <span class="status-name-text" style="font-weight: 500;"><%= status.name %></span>
                            <input type="hidden" name="statuses[][name]" class="status-name-input" value="<%= status.name %>">
                            <input type="hidden" name="statuses[][key]" class="status-key-input" value="<%= status.key %>">
                          </div>

                          <div class="status-category-display" style="min-width: 100px;">
                            <span class="badge <%= category_badge_class(status.category.to_sym) %>"><%= status.category_label %></span>
                            <input type="hidden" name="statuses[][category]" class="status-category-input" value="<%= status.category %>">
                          </div>

                          <div class="status-flags" style="display: flex; gap: 15px; min-width: 180px;">
                            <label style="font-size: 0.85em; display: flex; align-items: center; gap: 4px; margin: 0;">
                              <input type="checkbox" name="statuses[][is_initial]" value="1" class="status-initial-input" <%= 'checked' if status.is_initial %>>
                              Initial
                            </label>
                            <label style="font-size: 0.85em; display: flex; align-items: center; gap: 4px; margin: 0;">
                              <input type="checkbox" name="statuses[][is_end]" value="1" class="status-end-input" <%= 'checked' if status.is_end %>>
                              End
                            </label>
                          </div>

                          <input type="hidden" name="statuses[][position]" class="status-position-input" value="<%= index %>">

                          <button type="button"
                                  class="btn btn-danger btn-sm"
                                  data-action="click->form-builder#removeStatus"
                                  style="padding: 4px 8px;">
                            Remove
                          </button>
                        </div>
                      </div>
                    <% else %>
                      <div class="status-item custom-status-item" data-form-builder-target="statusItem" style="background: #fff3cd; padding: 10px 12px; margin-bottom: 8px; border-radius: 6px; border-left: 3px solid #ffc107;">
                        <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
                          <span class="status-position" style="font-weight: bold; color: #6c757d; min-width: 30px;">#<%= index + 1 %></span>

                          <div style="flex: 1; min-width: 150px;">
                            <input type="text"
                                   name="statuses[][name]"
                                   class="form-control form-control-sm status-name-input"
                                   placeholder="Status name"
                                   value="<%= status.name %>"
                                   required
                                   data-action="input->form-builder#generateStatusKey">
                            <input type="hidden" name="statuses[][key]" class="status-key-input" value="<%= status.key %>">
                          </div>

                          <div style="min-width: 140px;">
                            <select name="statuses[][category]"
                                    class="form-control form-control-sm status-category-input"
                                    required>
                              <option value="">Map to category...</option>
                              <option value="pending" <%= 'selected' if status.category == 'pending' %>>Pending</option>
                              <option value="in_review" <%= 'selected' if status.category == 'in_review' %>>In Review</option>
                              <option value="approved" <%= 'selected' if status.category == 'approved' %>>Approved</option>
                              <option value="denied" <%= 'selected' if status.category == 'denied' %>>Denied</option>
                              <option value="cancelled" <%= 'selected' if status.category == 'cancelled' %>>Cancelled</option>
                              <option value="scheduled" <%= 'selected' if status.category == 'scheduled' %>>Scheduled</option>
                            </select>
                          </div>

                          <div class="status-flags" style="display: flex; gap: 15px; min-width: 180px;">
                            <label style="font-size: 0.85em; display: flex; align-items: center; gap: 4px; margin: 0;">
                              <input type="checkbox" name="statuses[][is_initial]" value="1" class="status-initial-input" <%= 'checked' if status.is_initial %>>
                              Initial
                            </label>
                            <label style="font-size: 0.85em; display: flex; align-items: center; gap: 4px; margin: 0;">
                              <input type="checkbox" name="statuses[][is_end]" value="1" class="status-end-input" <%= 'checked' if status.is_end %>>
                              End
                            </label>
                          </div>

                          <input type="hidden" name="statuses[][position]" class="status-position-input" value="<%= index %>">

                          <button type="button"
                                  class="btn btn-danger btn-sm"
                                  data-action="click->form-builder#removeStatus"
                                  style="padding: 4px 8px;">
                            Remove
                          </button>
                        </div>
                      </div>
                    <% end %>
                  <% end %>
                <% end %>
              </div>
              <div style="display: flex; gap: 10px; margin-top: 10px;">
                <button type="button"
                        class="btn btn-secondary btn-sm"
                        data-action="click->form-builder#showStatusPicker">
                  + Add Predefined Status
                </button>
                <button type="button"
                        class="btn btn-secondary btn-sm"
                        data-action="click->form-builder#addCustomStatus">
                  + Add Custom Status
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- ========== Page 5: Form Fields ========== -->
        <div class="wizard-page" data-form-builder-target="wizardPage" data-wizard-title="Form Fields" style="display: none;">
          <div class="form-group">
            <label>Fields</label>
            <small class="form-text" style="display: block; margin-bottom: 10px; color: #6c757d;">
              These are custom fields that will appear on your form pages.
              <br><strong>Tip:</strong> Drag the &#x2630; handle to reorder fields.
            </small>

            <div class="fields-container" data-form-builder-target="fieldsContainer">
              <% if @form_template.form_fields.any? %>
                <% @form_template.form_fields.ordered.each_with_index do |field, index| %>
                  <div class="field-item" data-form-builder-target="fieldItem" style="background: #f8f9fa; padding: 15px; margin-bottom: 15px; border-radius: 6px;">
                    <div class="field-row" style="display: flex; gap: 10px; align-items: flex-start; flex-wrap: wrap;">
                      <div class="drag-handle" title="Drag to reorder" style="display: flex; flex-direction: column; align-items: center; justify-content: center; cursor: grab; padding: 8px 12px; background: #e9ecef; border-radius: 4px; min-width: 50px;">
                        <span class="field-position" style="font-size: 11px; font-weight: 700; color: #4CAF50;">#<%= index + 1 %></span>
                        <span class="drag-icon" style="font-size: 16px; color: #6c757d;">&#x2630;</span>
                      </div>

                      <div class="field-input" style="flex: 1; min-width: 200px;">
                        <label style="font-size: 0.9em; color: #495057; display: block; margin-bottom: 5px;">Label</label>
                        <input type="text"
                               name="fields[][label]"
                               class="form-control form-control-sm"
                               value="<%= field.label %>"
                               required>
                      </div>

                      <div class="field-input" style="flex: 0 0 150px;">
                        <label style="font-size: 0.9em; color: #495057; display: block; margin-bottom: 5px;">Type</label>
                        <select name="fields[][field_type]"
                                class="form-control form-control-sm"
                                data-action="change->form-builder#handleFieldTypeChange"
                                required>
                          <option value="text" <%= 'selected' if field.field_type == 'text' %>>Text</option>
                          <option value="text_box" <%= 'selected' if field.field_type == 'text_box' %>>Text Box</option>
                          <option value="dropdown" <%= 'selected' if field.field_type == 'dropdown' %>>Dropdown</option>
                          <option value="choices_dropdown" <%= 'selected' if field.field_type == 'choices_dropdown' %>>Dropdown - Choices</option>
                          <option value="date" <%= 'selected' if field.field_type == 'date' %>>Date</option>
                          <option value="date_time" <%= 'selected' if field.field_type == 'date_time' %>>Date/Time</option>
                          <option value="phone" <%= 'selected' if field.field_type == 'phone' %>>Phone</option>
                          <option value="email" <%= 'selected' if field.field_type == 'email' %>>Email</option>
                          <option value="number" <%= 'selected' if field.field_type == 'number' %>>Number</option>
                          <option value="currency" <%= 'selected' if field.field_type == 'currency' %>>Currency</option>
                          <option value="yes_no" <%= 'selected' if field.field_type == 'yes_no' %>>Yes / No</option>
                          <option value="time" <%= 'selected' if field.field_type == 'time' %>>Time</option>
                          <option value="media_attachment" <%= 'selected' if field.field_type == 'media_attachment' %>>Media Attachment</option>
                          <option value="information" <%= 'selected' if field.field_type == 'information' %>>Information</option>
                          <option value="repeating_section" <%= 'selected' if field.field_type == 'repeating_section' %>>Repeating Section</option>
                        </select>
                      </div>

                      <div class="field-input" style="flex: 0 0 150px;">
                        <label style="font-size: 0.9em; color: #495057; display: block; margin-bottom: 5px;">Page</label>
                        <select name="fields[][page_number]"
                                class="form-control form-control-sm page-select"
                                required>
                          <% (1..@form_template.page_count).each do |page_num| %>
                            <option value="<%= page_num %>" <%= 'selected' if field.page_number == page_num %>>
                              Page <%= page_num %> - <%= @form_template.page_header(page_num) %>
                            </option>
                          <% end %>
                        </select>
                      </div>

                      <div class="field-input" style="flex: 0 0 80px;">
                        <label style="font-size: 0.9em; color: #495057; display: block; margin-bottom: 5px;">Required?</label>
                        <input type="checkbox"
                               name="fields[][required]"
                               value="1"
                               style="margin-top: 10px;"
                               <%= 'checked' if field.required %>>
                      </div>

                      <div class="field-input" style="flex: 0 0 140px;">
                        <label style="font-size: 0.9em; color: #495057; display: block; margin-bottom: 5px;">Read Only</label>
                        <select name="fields[][read_only]"
                                class="form-control form-control-sm"
                                style="min-width: 120px;">
                          <option value="none" <%= 'selected' if field.read_only == 'none' || field.read_only.nil? %>>No</option>
                          <option value="always" <%= 'selected' if field.read_only == 'always' %>>Always</option>
                          <option value="initial" <%= 'selected' if field.read_only == 'initial' %>>Initial Filing Only</option>
                        </select>
                      </div>

                      <div class="field-input" style="flex: 0 0 100px;">
                        <label style="font-size: 0.9em; color: #495057; display: block; margin-bottom: 5px;">Custom View</label>
                        <input type="checkbox"
                               name="fields[][has_custom_view]"
                               value="1"
                               style="margin-top: 10px;"
                               title="When checked, this field's view HTML will be preserved during form updates"
                               <%= 'checked' if field.has_custom_view %>>
                      </div>

                      <div style="flex: 0 0 auto;">
                        <label style="font-size: 0.9em; color: transparent; display: block; margin-bottom: 5px;">-</label>
                        <button type="button"
                                class="btn deny"
                                style="padding: 5px 10px; font-size: 0.875em;"
                                data-action="click->form-builder#removeField">
                          Remove
                        </button>
                      </div>
                    </div>

                    <!-- Text Box Options -->
                    <div class="field-options text-box-options" style="margin-top: 10px; <%= 'display: none;' unless field.text_box? %>">
                      <label style="font-size: 0.9em; color: #495057;">Rows:</label>
                      <input type="number"
                             name="fields[][rows]"
                             class="form-control form-control-sm"
                             value="<%= field.rows %>"
                             min="1"
                             max="20"
                             style="width: 100px;">
                    </div>

                    <!-- Dropdown Options -->
                    <div class="field-options dropdown-options" style="margin-top: 10px; <%= 'display: none;' unless field.dropdown? || field.choices_dropdown? %>">
                      <div style="display: flex; gap: 10px; align-items: center; margin-bottom: 8px;">
                        <label style="margin: 0; font-size: 0.85em; color: #495057;">Source:</label>
                        <label style="margin: 0; font-size: 0.85em; cursor: pointer;">
                          <input type="radio" class="dropdown-source-radio" value="manual"
                                 <%= 'checked' unless field.data_source? || field.custom_lookup? %>
                                 data-action="change->form-builder#handleDropdownSourceChange"
                                 style="margin-right: 4px;">
                          Manual Values
                        </label>
                        <% if field.data_source? %>
                          <%# Legacy source, retained only so existing fields stay editable %>
                          <label style="margin: 0; font-size: 0.85em; cursor: pointer;">
                            <input type="radio" class="dropdown-source-radio" value="database" checked
                                   data-action="change->form-builder#handleDropdownSourceChange"
                                   style="margin-right: 4px;">
                            Database Table (legacy)
                          </label>
                        <% end %>
                        <label style="margin: 0; font-size: 0.85em; cursor: pointer;">
                          <input type="radio" class="dropdown-source-radio" value="custom"
                                 <%= 'checked' if field.custom_lookup? %>
                                 data-action="change->form-builder#handleDropdownSourceChange"
                                 style="margin-right: 4px;">
                          Custom (any table)
                        </label>
                      </div>

                      <div class="dropdown-manual-values" style="<%= 'display: none;' if field.data_source? || field.custom_lookup? %>">
                        <label style="font-size: 0.9em; color: #495057;">Values (comma-separated):</label>
                        <input type="text"
                               name="fields[][dropdown_values]"
                               class="form-control form-control-sm"
                               value="<%= field.dropdown_values.join(', ') %>"
                               placeholder="Option 1, Option 2, Option 3"
                               data-action="change->form-builder#handleDropdownValuesChange blur->form-builder#handleDropdownValuesChange">
                      </div>

                      <% categorized = field.categorized_data_source? %>
                      <div class="dropdown-data-source" style="<%= 'display: none;' unless field.data_source? %>">
                        <div style="display: flex; gap: 10px; align-items: flex-end; flex-wrap: wrap;">
                          <div style="flex: 1; min-width: 150px;">
                            <label style="font-size: 0.9em; color: #495057;">Table:</label>
                            <select name="fields[][data_source]"
                                    class="form-control form-control-sm data-source-table-select"
                                    data-action="change->form-builder#handleDataSourceTableChange">
                              <option value="">Select table...</option>
                              <% FormField::DATA_SOURCES.each do |key, config| %>
                                <option value="<%= key %>"
                                        data-columns="<%= (config[:columns] || {}).to_json %>"
                                        data-categorized="<%= config[:kind] == :categorized %>"
                                        <%= 'selected' if field.data_source_table == key %>><%= config[:label] %></option>
                              <% end %>
                            </select>
                          </div>
                          <div class="data-source-column-wrapper" style="flex: 1; min-width: 150px; <%= 'display: none;' if categorized %>">
                            <label style="font-size: 0.9em; color: #495057;">Column:</label>
                            <select name="fields[][data_source_column]"
                                    class="form-control form-control-sm data-source-column-select">
                              <option value="">Select column...</option>
                              <% if field.data_source? && FormField::DATA_SOURCES[field.data_source_table] %>
                                <% (FormField::DATA_SOURCES[field.data_source_table][:columns] || {}).each do |col_key, col_label| %>
                                  <option value="<%= col_key %>" <%= 'selected' if field.data_source_column == col_key %>><%= col_label %></option>
                                <% end %>
                              <% end %>
                            </select>
                          </div>
                          <div class="data-source-category-wrapper" style="flex: 1; min-width: 150px; <%= 'display: none;' unless categorized %>">
                            <label style="font-size: 0.9em; color: #495057;">Category:</label>
                            <select name="fields[][data_source_category]"
                                    class="form-control form-control-sm data-source-category-select">
                              <option value="">Select category...</option>
                              <% if categorized %>
                                <% FormField.category_options_for(field.data_source_table).each do |cat_label, cat_id| %>
                                  <option value="<%= cat_id %>" <%= 'selected' if field.data_source_category.to_s == cat_id.to_s %>><%= cat_label %></option>
                                <% end %>
                              <% end %>
                            </select>
                          </div>
                        </div>
                        <div class="data-source-agency-option" style="<%= field.data_source_table == 'employees' ? '' : 'display: none;' %>margin-top: 8px;">
                          <label style="font-size: 0.9em; color: #495057;">Filter by Agency:</label>
                          <select name="fields[][data_source_agency]"
                                  class="form-control form-control-sm data-source-agency-select">
                            <option value="">All agencies</option>
                            <% Agency.order(:long_name).each do |agency| %>
                              <option value="<%= agency.agency_id %>" <%= 'selected' if field.options&.dig('data_source_agency') == agency.agency_id.to_s %>><%= agency.long_name %></option>
                            <% end %>
                          </select>
                        </div>
                      </div>

                      <% custom_cfg = field.custom_lookup_config || {} %>
                      <div class="dropdown-custom-source" style="<%= 'display: none;' unless field.custom_lookup? %>">
                        <div style="display: flex; gap: 10px; align-items: flex-end; flex-wrap: wrap;">
                          <div style="flex: 1; min-width: 130px;">
                            <label style="font-size: 0.9em; color: #495057;">Database:</label>
                            <select name="fields[][custom_database]"
                                    class="form-control form-control-sm custom-database-select"
                                    data-action="change->form-builder#handleCustomDatabaseChange">
                              <option value="">Select database...</option>
                              <option value="paperboy" <%= 'selected' if custom_cfg['database'] == 'paperboy' %>>Paperboy</option>
                              <option value="gsabss" <%= 'selected' if custom_cfg['database'] == 'gsabss' %>>GSABSS</option>
                            </select>
                          </div>
                          <div style="flex: 1; min-width: 130px;">
                            <label style="font-size: 0.9em; color: #495057;">Table:</label>
                            <select name="fields[][custom_table]"
                                    class="form-control form-control-sm custom-table-select"
                                    data-action="change->form-builder#handleCustomTableChange">
                              <option value="">Select table...</option>
                              <% if custom_cfg['table'].present? %>
                                <option value="<%= custom_cfg['table'] %>" selected><%= custom_cfg['table'] %></option>
                              <% end %>
                            </select>
                          </div>
                          <div style="flex: 1; min-width: 130px;">
                            <label style="font-size: 0.9em; color: #495057;">Column (values):</label>
                            <select name="fields[][custom_column]"
                                    class="form-control form-control-sm custom-column-select">
                              <option value="">Select column...</option>
                              <% if custom_cfg['column'].present? %>
                                <option value="<%= custom_cfg['column'] %>" selected><%= custom_cfg['column'] %></option>
                              <% end %>
                            </select>
                          </div>
                        </div>
                        <div style="display: flex; gap: 10px; align-items: flex-start; flex-wrap: wrap; margin-top: 8px;">
                          <div style="flex: 1; min-width: 130px;">
                            <label style="font-size: 0.9em; color: #495057;">Also join columns (optional):</label>
                            <select name="fields[][custom_join_columns][]" multiple size="4"
                                    class="form-control form-control-sm custom-join-columns-select">
                              <% Array(custom_cfg['join_columns']).each do |jc| %>
                                <option value="<%= jc %>" selected><%= jc %></option>
                              <% end %>
                            </select>
                            <small style="display: block; color: #6c757d; font-size: 0.78em; margin-top: 2px;">Ctrl/⌘-click to add columns. Their values are appended to the column above (e.g. first + last name).</small>
                          </div>
                          <div style="flex: 1; min-width: 130px;">
                            <label style="font-size: 0.9em; color: #495057;">Join separator:</label>
                            <input type="text" name="fields[][custom_join_separator]"
                                   class="form-control form-control-sm custom-join-separator-input"
                                   value="<%= custom_cfg['join_separator'] || ' ' %>"
                                   placeholder="(space)">
                            <small style="display: block; color: #6c757d; font-size: 0.78em; margin-top: 2px;">Placed between joined values. Defaults to a space.</small>
                          </div>
                        </div>
                        <div class="custom-category-filters-section" style="margin-top: 8px;">
                          <label style="font-size: 0.9em; color: #495057;">Category Filters (optional):</label>
                          <% category_filters = field.custom_lookup_category_filters %>
                          <div class="custom-category-filters">
                            <% category_filters.each do |cf| %>
                              <div class="custom-category-filter-row" style="display: flex; gap: 10px; align-items: flex-end; margin-bottom: 6px;">
                                <div style="flex: 1; min-width: 130px;">
                                  <select name="fields[][custom_category_columns][]"
                                          class="form-control form-control-sm custom-category-column-select"
                                          data-action="change->form-builder#handleCustomCategoryColumnChange">
                                    <option value="">— select column —</option>
                                    <option value="<%= cf['column'] %>" selected><%= cf['column'] %></option>
                                  </select>
                                </div>
                                <div style="flex: 0 0 auto; padding-bottom: 6px; color: #6c757d;">=</div>
                                <div style="flex: 1; min-width: 130px;">
                                  <select name="fields[][custom_category_values][]"
                                          class="form-control form-control-sm custom-category-value-select">
                                    <option value="">Select value...</option>
                                    <% if cf['value'].present? %>
                                      <option value="<%= cf['value'] %>" selected><%= cf['value'] %></option>
                                    <% end %>
                                  </select>
                                </div>
                                <button type="button" class="btn btn-sm" style="flex: 0 0 auto;"
                                        data-action="click->form-builder#removeCustomCategoryFilter"
                                        title="Remove filter">×</button>
                              </div>
                            <% end %>
                          </div>
                          <button type="button" class="btn btn-sm"
                                  data-action="click->form-builder#addCustomCategoryFilter">+ Add category filter</button>
                          <small style="display: block; color: #6c757d; font-size: 0.78em; margin-top: 2px;">Limit the values shown. Multiple rows on the same column match any of those values (OR); different columns must all match (AND).</small>
                        </div>
                        <div style="display: flex; gap: 10px; align-items: flex-end; flex-wrap: wrap; margin-top: 8px;">
                          <div style="flex: 1; min-width: 130px;">
                            <label style="font-size: 0.9em; color: #495057;">Order by (optional):</label>
                            <select name="fields[][custom_order_column]"
                                    class="form-control form-control-sm custom-order-column-select">
                              <option value="">— default (by value) —</option>
                              <% if custom_cfg['order_column'].present? %>
                                <option value="<%= custom_cfg['order_column'] %>" selected><%= custom_cfg['order_column'] %></option>
                              <% end %>
                            </select>
                          </div>
                          <div style="flex: 1; min-width: 130px;">
                            <label style="font-size: 0.9em; color: #495057;">Sort direction:</label>
                            <select name="fields[][custom_order_direction]"
                                    class="form-control form-control-sm custom-order-direction-select">
                              <option value="asc" <%= 'selected' unless custom_cfg['order_direction'] == 'desc' %>>Ascending (A→Z, 1→9)</option>
                              <option value="desc" <%= 'selected' if custom_cfg['order_direction'] == 'desc' %>>Descending (Z→A, 9→1)</option>
                            </select>
                          </div>
                        </div>
                      </div>
                    </div>

                    <!-- Information Options -->
                    <div class="field-options information-options" style="margin-top: 10px; padding: 8px; background: #e8f4f8; border-radius: 4px; border-left: 3px solid #0c5460; <%= 'display: none;' unless field.information? %>">
                      <label style="font-size: 0.85em; color: #495057; display: block; margin-bottom: 4px;">Information Text (shown in modal):</label>
                      <textarea name="fields[][information_text]"
                                class="form-control form-control-sm"
                                rows="4"
                                placeholder="Enter the terms or information that will appear in the modal..."><%= field.information_text %></textarea>
                      <label style="font-size: 0.85em; color: #495057; display: inline-flex; align-items: center; gap: 6px; margin-top: 6px;">
                        <input type="checkbox" name="fields[][acknowledgeable]" value="1" <%= 'checked' if field.acknowledgeable? %>>
                        Requires acknowledgement (user must agree before submitting)
                      </label>
                    </div>

                    <!-- Field Restriction Options -->
                    <div class="field-options field-restriction-options" style="margin-top: 10px; padding: 8px; background: #e9ecef; border-radius: 4px;">
                      <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
                        <label style="margin: 0; font-size: 0.85em; color: #495057;">Fill out by:</label>
                        <select name="fields[][restricted_to_type]"
                                class="form-control form-control-sm restriction-type-select"
                                data-action="change->form-builder#toggleFieldRestriction"
                                style="width: auto; min-width: 150px;">
                          <option value="none" <%= 'selected' if field.restricted_to_type == 'none' || field.restricted_to_type.nil? %>>Anyone (Submitter)</option>
                          <option value="employee" <%= 'selected' if field.restricted_to_type == 'employee' %>>Specific Employee</option>
                          <option value="group" <%= 'selected' if field.restricted_to_type == 'group' %>>Group</option>
                        </select>

                        <div class="restriction-employee-select" style="<%= 'display: none;' unless field.restricted_to_type == 'employee' %>">
                          <select name="fields[][restricted_to_employee_id]"
                                  class="form-control form-control-sm restriction-employee-dropdown"
                                  style="min-width: 200px;">
                            <option value="">Select employee...</option>
                            <% @employees.each do |emp| %>
                              <option value="<%= emp[1] %>" <%= 'selected' if field.restricted_to_employee_id == emp[1] %>><%= emp[0] %></option>
                            <% end %>
                          </select>
                        </div>

                        <div class="restriction-group-select" style="<%= 'display: none;' unless field.restricted_to_type == 'group' %>">
                          <select name="fields[][restricted_to_group_id]"
                                  class="form-control form-control-sm restriction-group-dropdown"
                                  style="min-width: 200px;">
                            <option value="">Select group...</option>
                            <% @acl_groups.each do |group| %>
                              <option value="<%= group[1] %>" <%= 'selected' if field.restricted_to_group_id == group[1] %>><%= group[0] %></option>
                            <% end %>
                          </select>
                        </div>

                        <div class="restriction-org-filter-select" style="<%= 'display: none;' unless field.restricted_to_type == 'group' %>">
                          <select name="fields[][restricted_to_org_filter_level]"
                                  class="form-control form-control-sm restriction-org-filter-dropdown"
                                  style="min-width: 200px;"
                                  title="Restrict group members to those matching the submitter at this org level">
                            <option value="">Filter by submitter's…</option>
                            <% FormTemplateRoutingStep::ORG_FILTER_LEVELS.each do |lvl| %>
                              <option value="<%= lvl %>" <%= 'selected' if field.restricted_to_org_filter_level == lvl %>>Filter by submitter's <%= FormTemplateRoutingStep::ORG_FILTER_LABELS[lvl] %></option>
                            <% end %>
                          </select>
                        </div>

                        <div class="restriction-visibility-select" style="<%= 'display: none;' if field.restricted_to_type.blank? || field.restricted_to_type == 'none' %>">
                          <label style="margin: 0 6px 0 0; font-size: 0.85em; color: #495057;">Visible to:</label>
                          <select name="fields[][visible_to_filler]"
                                  class="form-control form-control-sm restriction-visibility-dropdown"
                                  style="width: auto; min-width: 170px;">
                            <option value="0" <%= 'selected' unless field.visible_to_filler? %>>Everyone</option>
                            <option value="1" <%= 'selected' if field.visible_to_filler? %>>Only the filler</option>
                          </select>
                        </div>
                      </div>
                    </div>

                    <!-- Conditional Logic Options -->
                    <div class="field-options conditional-options" style="margin-top: 10px; padding: 8px; background: #fff3cd; border-radius: 4px; border-left: 3px solid #ffc107;">
                      <input type="hidden" name="fields[][conditional_enabled]" class="conditional-enabled-input" value="<%= field.conditional? ? '1' : '0' %>">
                      <div style="display: flex; gap: 10px; align-items: flex-start; flex-wrap: wrap;">
                        <label style="margin: 0; font-size: 0.85em; color: #495057; padding-top: 5px;">
                          <input type="checkbox"
                                 class="conditional-toggle"
                                 data-action="change->form-builder#toggleConditionalOptions"
                                 style="margin-right: 5px;"
                                 <%= 'checked' if field.conditional? %>>
                          Show conditionally
                        </label>

                        <%
                          ordered_fields = @form_template.form_fields.ordered.to_a
                          dropdown_fields_with_index = ordered_fields.each_with_index.select { |f, _| f.dropdown? || f.choices_dropdown? }
                          conditional_field_index = field.conditional_field_id ? ordered_fields.index { |f| f.id == field.conditional_field_id } : nil
                        %>
                        <div class="conditional-config" style="<%= 'display: none;' unless field.conditional? %> flex: 1; min-width: 300px;">
                          <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin-bottom: 8px;">
                            <span style="font-size: 0.85em; color: #495057;">When</span>
                            <select class="form-control form-control-sm conditional-field-select"
                                    name="fields[][conditional_field_id]"
                                    data-action="change->form-builder#updateConditionalValues"
                                    style="width: auto; min-width: 150px;">
                              <option value="">Select dropdown...</option>
                              <% dropdown_fields_with_index.each do |dropdown, dropdown_index| %>
                                <% next if dropdown.id == field.id %>
                                <option value="field_<%= dropdown_index %>"
                                        data-field-index="<%= dropdown_index %>"
                                        data-values="<%= dropdown.dropdown_values.to_json %>"
                                        <%= 'selected' if conditional_field_index == dropdown_index %>>
                                  <%= dropdown.label %>
                                </option>
                              <% end %>
                            </select>
                            <span style="font-size: 0.85em; color: #495057;">equals:</span>
                          </div>
                          <div class="conditional-values-container" style="display: flex; flex-wrap: wrap; gap: 8px;">
                            <% if field.conditional? && field.conditional_field %>
                              <% field.conditional_field.dropdown_values.each do |value| %>
                                <label style="font-size: 0.8em; display: flex; align-items: center; gap: 4px; background: #fff; padding: 4px 8px; border-radius: 4px; border: 1px solid #ddd;">
                                  <input type="checkbox"
                                         name="fields[][conditional_values][]"
                                         value="<%= value %>"
                                         <%= 'checked' if field.conditional_values&.include?(value) %>>
                                  <%= value %>
                                </label>
                              <% end %>
                            <% else %>
                              <span style="font-size: 0.8em; color: #6c757d; font-style: italic;">Select a dropdown field first</span>
                            <% end %>
                          </div>
                        </div>
                      </div>
                    </div>

                    <!-- Repeating Section Options -->
                    <div class="field-options repeating-section-options" style="margin-top: 10px; padding: 8px; background: #ede7f6; border-radius: 4px; border-left: 3px solid #6f42c1; <%= 'display: none;' unless field.repeating_section? %>">
                      <div style="display: flex; gap: 15px; flex-wrap: wrap; align-items: flex-end;">
                        <div>
                          <label style="font-size: 0.85em; color: #495057; display: block;">Min entries</label>
                          <input type="number" name="fields[][repeat_min]" class="form-control form-control-sm" min="0" value="<%= field.repeating_section? ? field.repeat_min : 1 %>" style="width: 90px;">
                        </div>
                        <div>
                          <label style="font-size: 0.85em; color: #495057; display: block;">Max (0 = &infin;)</label>
                          <input type="number" name="fields[][repeat_max]" class="form-control form-control-sm" min="0" value="<%= field.repeating_section? ? field.repeat_max : 0 %>" style="width: 90px;">
                        </div>
                        <div style="flex: 1; min-width: 180px;">
                          <label style="font-size: 0.85em; color: #495057; display: block;">Add button label</label>
                          <input type="text" name="fields[][add_label]" class="form-control form-control-sm" value="<%= field.repeating_section? ? field.options&.dig('add_label') : '' %>" placeholder="+ Add">
                        </div>
                      </div>
                      <small style="display: block; margin-top: 6px; color: #6c757d; font-size: 0.8em;">
                        Assign fields to this section using each field's &ldquo;Repeats in section&rdquo; selector. They repeat together as a group with a + button.
                      </small>
                    </div>

                    <!-- Repeat Group Assignment -->
                    <%
                      section_fields_with_index = ordered_fields.each_with_index.select { |f, _| f.repeating_section? }
                      current_section_index = field.repeat_group ? ordered_fields.index { |f| f.field_name == field.repeat_group } : nil
                    %>
                    <div class="field-options repeat-group-row" style="margin-top: 10px; <%= 'display: none;' if field.repeating_section? %>">
                      <label style="font-size: 0.85em; color: #495057; margin-right: 6px;">Repeats in section:</label>
                      <select class="form-control form-control-sm repeat-group-select" name="fields[][repeat_group]"
                              data-action="change->form-builder#handleRepeatGroupChange"
                              style="width: auto; min-width: 180px; display: inline-block;">
                        <option value="">&mdash; Not in a section &mdash;</option>
                        <% section_fields_with_index.each do |section, section_index| %>
                          <% next if section.id == field.id %>
                          <option value="field_<%= section_index %>" <%= 'selected' if current_section_index == section_index %>><%= section.label %></option>
                        <% end %>
                      </select>
                    </div>

                    <!-- Conditional Answer Options (available for any field type) -->
                    <%
                      conditional_answer_field_index = field.conditional_answer_field_id ? ordered_fields.index { |f| f.id == field.conditional_answer_field_id } : nil
                      al = field.answer_lookup_config || {}
                      answer_lookup_mode = field.answer_lookup?
                    %>
                    <div class="field-options conditional-answer-options" style="margin-top: 10px; padding: 8px; background: #d4edda; border-radius: 4px; border-left: 3px solid #28a745;">
                      <input type="hidden" name="fields[][conditional_answer_enabled]" class="conditional-answer-enabled-input" value="<%= field.conditional_answer? ? '1' : '0' %>">
                      <div style="display: flex; gap: 10px; align-items: flex-start; flex-wrap: wrap;">
                        <label style="margin: 0; font-size: 0.85em; color: #495057; padding-top: 5px;">
                          <input type="checkbox"
                                 class="conditional-answer-toggle"
                                 data-action="change->form-builder#toggleConditionalAnswerOptions"
                                 style="margin-right: 5px;"
                                 <%= 'checked' if field.conditional_answer? %>>
                          Answer conditionally
                        </label>

                        <div class="conditional-answer-config" style="<%= 'display: none;' unless field.conditional_answer? %> flex: 1; min-width: 300px;">
                          <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin-bottom: 8px;">
                            <span style="font-size: 0.85em; color: #495057;">When</span>
                            <select class="form-control form-control-sm conditional-answer-field-select"
                                    name="fields[][conditional_answer_field_id]"
                                    data-action="change->form-builder#updateConditionalAnswerMappings"
                                    style="width: auto; min-width: 150px;">
                              <option value="">Select dropdown...</option>
                              <% dropdown_fields_with_index.each do |dropdown, dropdown_index| %>
                                <% next if dropdown.id == field.id %>
                                <option value="field_<%= dropdown_index %>"
                                        data-field-index="<%= dropdown_index %>"
                                        data-values="<%= dropdown.dropdown_values.to_json %>"
                                        <%= 'selected' if conditional_answer_field_index == dropdown_index %>>
                                  <%= dropdown.label %>
                                </option>
                              <% end %>
                            </select>
                            <span style="font-size: 0.85em; color: #495057;">is selected,</span>
                          </div>

                          <label style="display: block; font-size: 0.8em; color: #495057; margin-bottom: 8px;">
                            <input type="checkbox"
                                   class="answer-lookup-toggle"
                                   name="fields[][answer_mode]"
                                   value="lookup"
                                   data-action="change->form-builder#toggleAnswerMode"
                                   style="margin-right: 5px;"
                                   <%= 'checked' if answer_lookup_mode %>>
                            Auto-fill this field from a database table (instead of a fixed answer)
                          </label>

                          <!-- Static value -> value mapping -->
                          <div class="conditional-answer-mappings-container" style="display: <%= answer_lookup_mode ? 'none' : 'flex' %>; flex-direction: column; gap: 6px;">
                            <% if field.conditional_answer? && !answer_lookup_mode && field.conditional_answer_field %>
                              <% field.conditional_answer_field.dropdown_values.each do |trigger_value| %>
                                <div style="display: flex; align-items: center; gap: 8px; font-size: 0.8em;">
                                  <span style="min-width: 120px; background: #fff; padding: 4px 8px; border-radius: 4px; border: 1px solid #ddd;"><%= trigger_value %></span>
                                  <span style="color: #495057;">&rarr;</span>
                                  <select name="fields[][conditional_answer_mappings][<%= trigger_value %>]"
                                          class="form-control form-control-sm"
                                          style="width: auto; min-width: 120px;">
                                    <option value="">No auto-answer</option>
                                    <% field.dropdown_values.each do |answer_value| %>
                                      <option value="<%= answer_value %>" <%= 'selected' if field.conditional_answer_mappings&.dig(trigger_value) == answer_value %>><%= answer_value %></option>
                                    <% end %>
                                  </select>
                                </div>
                              <% end %>
                            <% else %>
                              <span style="font-size: 0.8em; color: #6c757d; font-style: italic;">Select a trigger dropdown first</span>
                            <% end %>
                          </div>

                          <!-- Table-lookup autofill -->
                          <div class="answer-lookup-panel" style="display: <%= answer_lookup_mode ? 'flex' : 'none' %>; flex-wrap: wrap; gap: 8px; align-items: center;">
                            <select class="form-control form-control-sm answer-lookup-database"
                                    name="fields[][answer_lookup][database]"
                                    data-action="change->form-builder#loadAnswerLookupTables"
                                    style="width: auto;">
                              <option value="paperboy" <%= 'selected' if al['database'] == 'paperboy' %>>Paperboy</option>
                              <option value="gsabss" <%= 'selected' if al['database'] == 'gsabss' %>>GSABSS (reference)</option>
                            </select>
                            <select class="form-control form-control-sm answer-lookup-table"
                                    name="fields[][answer_lookup][table]"
                                    data-action="change->form-builder#loadAnswerLookupColumns"
                                    style="width: auto; min-width: 130px;">
                              <option value="">Select table...</option>
                              <% if al['table'].present? %><option value="<%= al['table'] %>" selected><%= al['table'] %></option><% end %>
                            </select>
                            <span style="font-size: 0.8em; color: #495057;">match on</span>
                            <select class="form-control form-control-sm answer-lookup-match-column"
                                    name="fields[][answer_lookup][match_column]"
                                    style="width: auto; min-width: 120px;">
                              <option value="">column...</option>
                              <% if al['match_column'].present? %><option value="<%= al['match_column'] %>" selected><%= al['match_column'] %></option><% end %>
                            </select>
                            <span style="font-size: 0.8em; color: #495057;">&rarr; fill with</span>
                            <select class="form-control form-control-sm answer-lookup-return-column"
                                    name="fields[][answer_lookup][return_column]"
                                    style="width: auto; min-width: 120px;">
                              <option value="">column...</option>
                              <% if al['return_column'].present? %><option value="<%= al['return_column'] %>" selected><%= al['return_column'] %></option><% end %>
                            </select>
                            <div style="flex-basis: 100%; display: flex; gap: 12px; align-items: flex-start; flex-wrap: wrap; margin-top: 4px;">
                              <div style="display: flex; flex-direction: column; min-width: 200px;">
                                <label style="font-size: 0.8em; color: #495057;">+ also combine columns (optional):</label>
                                <div class="answer-lookup-join-chips" style="display: flex; flex-wrap: wrap; gap: 4px; margin: 2px 0;">
                                  <% Array(al['return_join_columns']).each do |jc| %>
                                    <span class="answer-lookup-join-chip" data-column="<%= jc %>" style="display: inline-flex; align-items: center; gap: 4px; background: #e9ecef; border: 1px solid #ced4da; border-radius: 12px; padding: 2px 8px; font-size: 0.78em; color: #333;"><%= jc %><button type="button" class="answer-lookup-join-remove" data-action="click->form-builder#removeAnswerJoinColumn" aria-label="Remove <%= jc %>" style="border: none; background: none; cursor: pointer; color: #888; font-size: 1.05em; line-height: 1; padding: 0;">&times;</button><input type="hidden" name="fields[][answer_lookup][return_join_columns][]" value="<%= jc %>"></span>
                                  <% end %>
                                </div>
                                <select class="form-control form-control-sm answer-lookup-return-join-add"
                                        data-action="change->form-builder#addAnswerJoinColumn"
                                        style="width: auto; min-width: 180px;">
                                  <option value="">+ add a column&hellip;</option>
                                </select>
                                <small style="display: block; color: #6c757d; font-size: 0.75em; margin-top: 2px;">Pick columns to append to the fill column above (e.g. first + last name).</small>
                              </div>
                              <div style="display: flex; flex-direction: column; min-width: 90px;">
                                <label style="font-size: 0.8em; color: #495057;">Join separator:</label>
                                <input type="text" class="form-control form-control-sm answer-lookup-return-separator"
                                       name="fields[][answer_lookup][return_join_separator]"
                                       value="<%= al['return_join_separator'] || ' ' %>"
                                       placeholder="(space)" style="width: 90px;">
                                <small style="display: block; color: #6c757d; font-size: 0.75em; margin-top: 2px;">Placed between joined values. Defaults to a space.</small>
                              </div>
                            </div>
                            <small style="flex-basis: 100%; font-size: 0.75em; color: #6c757d; font-style: italic;">
                              The trigger's displayed value is matched against the match column, so the trigger should list values from this same table/column. First matching row wins.
                            </small>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                <% end %>
              <% end %>
            </div>

            <button type="button"
                    class="btn btn-secondary btn-sm"
                    style="margin-top: 15px;"
                    data-action="click->form-builder#addField">
              + Add Field
            </button>
          </div>
        </div>

        <!-- ========== Page 6: Dashboard ========== -->
        <div class="wizard-page" data-form-builder-target="wizardPage" data-wizard-title="Dashboard" style="display: none;">
          <div class="form-group">
            <%= f.label :records_table, "Show in Records?" %>
            <%= f.select :records_table,
                        options_for_select([['No', false], ['Yes', true]], @form_template.records_table),
                        {},
                        { class: "form-control" } %>
            <small class="form-text" style="color: #6c757d;">
              Surfaces this form's submissions as a customizable table in the Records area.
            </small>
          </div>

          <div class="form-group">
            <%= f.label :has_dashboard, "Enable Dashboard?" %>
            <%= f.select :has_dashboard,
                        options_for_select([['No', false], ['Yes', true]], @form_template.has_dashboard),
                        {},
                        {
                          id: "has_dashboard_select",
                          class: "form-control",
                          data: {
                            action: "change->form-builder#toggleMetabaseFields"
                          }
                        } %>
          </div>

          <div id="metabase-fields" style="<%= 'display: none;' unless @form_template.has_dashboard %>">
            <div class="form-group">
              <%= f.label :metabase_dashboard_id, "Metabase Dashboard ID" %>
              <%= f.number_field :metabase_dashboard_id,
                              class: "form-control",
                              placeholder: "e.g., 1" %>
              <small class="form-text" style="color: #6c757d;">
                Find this in Metabase: the number in the dashboard URL (e.g., /dashboard/1)
              </small>
            </div>
          </div>
        </div>

      </div>

      <div class="modal-footer wizard-footer">
        <%= link_to "Cancel", form_template_path(@form_template), class: "btn btn-secondary" %>
        <div class="wizard-nav">
          <button type="button"
                  class="btn btn-secondary"
                  data-form-builder-target="wizardPrevBtn"
                  data-action="click->form-builder#wizardPrev"
                  style="display: none;">
            &larr; Previous
          </button>
          <div class="progress-dots">
            <span class="dot active" data-form-builder-target="wizardDot"></span>
            <span class="dot" data-form-builder-target="wizardDot"></span>
            <span class="dot" data-form-builder-target="wizardDot"></span>
            <span class="dot" data-form-builder-target="wizardDot"></span>
            <span class="dot" data-form-builder-target="wizardDot"></span>
            <span class="dot" data-form-builder-target="wizardDot"></span>
          </div>
          <button type="button"
                  class="btn btn-primary"
                  data-form-builder-target="wizardNextBtn"
                  data-action="click->form-builder#wizardNext">
            Next &rarr;
          </button>
          <%= f.submit "Update Form Template",
                      class: "btn btn-primary",
                      style: "display: none;",
                      data: {
                        form_builder_target: "submitButton wizardSubmitBtn",
                        confirm: "Are you sure you want to update this form template? Any routing changes will regenerate the controller file."
                      } %>
        </div>
      </div>
    <% end %>

    <!-- Status Picker Modal -->
    <div id="status-picker-modal" class="modal" style="display: none;">
      <div class="modal-content" style="max-width: 500px; max-height: 80vh; overflow-y: auto;">
        <div class="modal-header" style="padding: 15px; border-bottom: 1px solid #dee2e6;">
          <h3 style="margin: 0;">Select Predefined Status</h3>
          <button type="button" class="close-modal" data-action="click->form-builder#closeStatusPicker">&times;</button>
        </div>
        <div class="modal-body" style="padding: 15px;">
          <div class="predefined-statuses-list" data-form-builder-target="predefinedStatusesList">
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Custom-lookup category filter row (cloned by + Add category filter) -->
<template id="custom-category-filter-template">
  <div class="custom-category-filter-row" style="display: flex; gap: 10px; align-items: flex-end; margin-bottom: 6px;">
    <div style="flex: 1; min-width: 130px;">
      <select name="fields[][custom_category_columns][]"
              class="form-control form-control-sm custom-category-column-select"
              data-action="change->form-builder#handleCustomCategoryColumnChange">
        <option value="">— select column —</option>
      </select>
    </div>
    <div style="flex: 0 0 auto; padding-bottom: 6px; color: #6c757d;">=</div>
    <div style="flex: 1; min-width: 130px;">
      <select name="fields[][custom_category_values][]"
              class="form-control form-control-sm custom-category-value-select">
        <option value="">Select value...</option>
      </select>
    </div>
    <button type="button" class="btn btn-sm" style="flex: 0 0 auto;"
            data-action="click->form-builder#removeCustomCategoryFilter"
            title="Remove filter">×</button>
  </div>
</template>

<!-- Field Template (hidden, used for cloning when adding new fields) -->
<template id="field-template">
  <div class="field-item" data-form-builder-target="fieldItem" style="background: #f8f9fa; padding: 15px; margin-bottom: 15px; border-radius: 6px;">
    <div class="field-row" style="display: flex; gap: 10px; align-items: flex-start; flex-wrap: wrap;">
      <div class="drag-handle" title="Drag to reorder" style="display: flex; flex-direction: column; align-items: center; justify-content: center; cursor: grab; padding: 8px 12px; background: #e9ecef; border-radius: 4px; min-width: 50px;">
        <span class="field-position" style="font-size: 11px; font-weight: 700; color: #4CAF50;">#1</span>
        <span class="drag-icon" style="font-size: 16px; color: #6c757d;">&#x2630;</span>
      </div>

      <div class="field-input" style="flex: 1; min-width: 200px;">
        <label style="font-size: 0.9em; color: #495057; display: block; margin-bottom: 5px;">Label</label>
        <input type="text"
               name="fields[][label]"
               class="form-control form-control-sm"
               placeholder="e.g., Employee Name"
               required>
      </div>

      <div class="field-input" style="flex: 0 0 150px;">
        <label style="font-size: 0.9em; color: #495057; display: block; margin-bottom: 5px;">Type</label>
        <select name="fields[][field_type]"
                class="form-control form-control-sm"
                data-action="change->form-builder#handleFieldTypeChange"
                required>
          <option value="text">Text</option>
          <option value="text_box">Text Box</option>
          <option value="dropdown">Dropdown</option>
          <option value="choices_dropdown">Dropdown - Choices</option>
          <option value="date">Date</option>
          <option value="date_time">Date/Time</option>
          <option value="phone">Phone</option>
          <option value="email">Email</option>
          <option value="number">Number</option>
          <option value="yes_no">Yes / No</option>
          <option value="time">Time</option>
          <option value="media_attachment">Media Attachment</option>
          <option value="information">Information</option>
          <option value="repeating_section">Repeating Section</option>
        </select>
      </div>

      <div class="field-input" style="flex: 0 0 150px;">
        <label style="font-size: 0.9em; color: #495057; display: block; margin-bottom: 5px;">Page</label>
        <select name="fields[][page_number]"
                class="form-control form-control-sm page-select"
                required>
          <option value="1">Page 1 - Employee Info</option>
          <option value="2">Page 2 - Agency Info</option>
        </select>
      </div>

      <div class="field-input" style="flex: 0 0 80px;">
        <label style="font-size: 0.9em; color: #495057; display: block; margin-bottom: 5px;">Required?</label>
        <input type="checkbox"
               name="fields[][required]"
               value="1"
               style="margin-top: 10px;">
      </div>

      <div class="field-input" style="flex: 0 0 140px;">
        <label style="font-size: 0.9em; color: #495057; display: block; margin-bottom: 5px;">Read Only</label>
        <select name="fields[][read_only]"
                class="form-control form-control-sm"
                style="min-width: 120px;">
          <option value="none">No</option>
          <option value="always">Always</option>
          <option value="initial">Initial Filing Only</option>
        </select>
      </div>

      <div class="field-input" style="flex: 0 0 100px;">
        <label style="font-size: 0.9em; color: #495057; display: block; margin-bottom: 5px;">Custom View</label>
        <input type="checkbox"
               name="fields[][has_custom_view]"
               value="1"
               style="margin-top: 10px;"
               title="When checked, this field's view HTML will be preserved during form updates">
      </div>

      <div style="flex: 0 0 auto;">
        <label style="font-size: 0.9em; color: transparent; display: block; margin-bottom: 5px;">-</label>
        <button type="button"
                class="btn deny"
                style="padding: 5px 10px; font-size: 0.875em;"
                data-action="click->form-builder#removeField">
          Remove
        </button>
      </div>
    </div>

    <!-- Text Box Options -->
    <div class="field-options text-box-options" style="margin-top: 10px; display: none;">
      <label style="font-size: 0.9em; color: #495057;">Rows:</label>
      <input type="number"
             name="fields[][rows]"
             class="form-control form-control-sm"
             value="5"
             min="1"
             max="20"
             style="width: 100px;">
    </div>

    <!-- Dropdown Options -->
    <div class="field-options dropdown-options" style="margin-top: 10px; display: none;">
      <div style="display: flex; gap: 10px; align-items: center; margin-bottom: 8px;">
        <label style="margin: 0; font-size: 0.85em; color: #495057;">Source:</label>
        <label style="margin: 0; font-size: 0.85em; cursor: pointer;">
          <input type="radio" class="dropdown-source-radio" value="manual" checked
                 data-action="change->form-builder#handleDropdownSourceChange"
                 style="margin-right: 4px;">
          Manual Values
        </label>
        <label style="margin: 0; font-size: 0.85em; cursor: pointer;">
          <input type="radio" class="dropdown-source-radio" value="custom"
                 data-action="change->form-builder#handleDropdownSourceChange"
                 style="margin-right: 4px;">
          Custom (any table)
        </label>
      </div>

      <div class="dropdown-manual-values">
        <label style="font-size: 0.9em; color: #495057;">Values (comma-separated):</label>
        <input type="text"
               name="fields[][dropdown_values]"
               class="form-control form-control-sm"
               placeholder="Option 1, Option 2, Option 3"
               data-action="change->form-builder#handleDropdownValuesChange blur->form-builder#handleDropdownValuesChange">
      </div>

      <div class="dropdown-custom-source" style="display: none;">
        <div style="display: flex; gap: 10px; align-items: flex-end; flex-wrap: wrap;">
          <div style="flex: 1; min-width: 130px;">
            <label style="font-size: 0.9em; color: #495057;">Database:</label>
            <select name="fields[][custom_database]"
                    class="form-control form-control-sm custom-database-select"
                    data-action="change->form-builder#handleCustomDatabaseChange">
              <option value="">Select database...</option>
              <option value="paperboy">Paperboy</option>
              <option value="gsabss">GSABSS</option>
            </select>
          </div>
          <div style="flex: 1; min-width: 130px;">
            <label style="font-size: 0.9em; color: #495057;">Table:</label>
            <select name="fields[][custom_table]"
                    class="form-control form-control-sm custom-table-select"
                    data-action="change->form-builder#handleCustomTableChange">
              <option value="">Select table...</option>
            </select>
          </div>
          <div style="flex: 1; min-width: 130px;">
            <label style="font-size: 0.9em; color: #495057;">Column (values):</label>
            <select name="fields[][custom_column]"
                    class="form-control form-control-sm custom-column-select">
              <option value="">Select column...</option>
            </select>
          </div>
        </div>
        <div style="display: flex; gap: 10px; align-items: flex-start; flex-wrap: wrap; margin-top: 8px;">
          <div style="flex: 1; min-width: 130px;">
            <label style="font-size: 0.9em; color: #495057;">Also join columns (optional):</label>
            <select name="fields[][custom_join_columns][]" multiple size="4"
                    class="form-control form-control-sm custom-join-columns-select">
            </select>
            <small style="display: block; color: #6c757d; font-size: 0.78em; margin-top: 2px;">Ctrl/⌘-click to add columns. Their values are appended to the column above (e.g. first + last name).</small>
          </div>
          <div style="flex: 1; min-width: 130px;">
            <label style="font-size: 0.9em; color: #495057;">Join separator:</label>
            <input type="text" name="fields[][custom_join_separator]"
                   class="form-control form-control-sm custom-join-separator-input"
                   value=" "
                   placeholder="(space)">
            <small style="display: block; color: #6c757d; font-size: 0.78em; margin-top: 2px;">Placed between joined values. Defaults to a space.</small>
          </div>
        </div>
        <div class="custom-category-filters-section" style="margin-top: 8px;">
          <label style="font-size: 0.9em; color: #495057;">Category Filters (optional):</label>
          <div class="custom-category-filters"></div>
          <button type="button" class="btn btn-sm"
                  data-action="click->form-builder#addCustomCategoryFilter">+ Add category filter</button>
          <small style="display: block; color: #6c757d; font-size: 0.78em; margin-top: 2px;">Limit the values shown. Multiple rows on the same column match any of those values (OR); different columns must all match (AND).</small>
        </div>
        <div style="display: flex; gap: 10px; align-items: flex-end; flex-wrap: wrap; margin-top: 8px;">
          <div style="flex: 1; min-width: 130px;">
            <label style="font-size: 0.9em; color: #495057;">Order by (optional):</label>
            <select name="fields[][custom_order_column]"
                    class="form-control form-control-sm custom-order-column-select">
              <option value="">— default (by value) —</option>
            </select>
          </div>
          <div style="flex: 1; min-width: 130px;">
            <label style="font-size: 0.9em; color: #495057;">Sort direction:</label>
            <select name="fields[][custom_order_direction]"
                    class="form-control form-control-sm custom-order-direction-select">
              <option value="asc" selected>Ascending (A→Z, 1→9)</option>
              <option value="desc">Descending (Z→A, 9→1)</option>
            </select>
          </div>
        </div>
      </div>
    </div>

    <!-- Information Options -->
    <div class="field-options information-options" style="display: none; margin-top: 10px; padding: 8px; background: #e8f4f8; border-radius: 4px; border-left: 3px solid #0c5460;">
      <label style="font-size: 0.85em; color: #495057; display: block; margin-bottom: 4px;">Information Text (shown in modal):</label>
      <textarea name="fields[][information_text]"
                class="form-control form-control-sm"
                rows="4"
                placeholder="Enter the terms or information that will appear in the modal..."></textarea>
      <label style="font-size: 0.85em; color: #495057; display: inline-flex; align-items: center; gap: 6px; margin-top: 6px;">
        <input type="checkbox" name="fields[][acknowledgeable]" value="1">
        Requires acknowledgement (user must agree before submitting)
      </label>
    </div>

    <!-- Field Restriction Options -->
    <div class="field-options field-restriction-options" style="margin-top: 10px; padding: 8px; background: #e9ecef; border-radius: 4px;">
      <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
        <label style="margin: 0; font-size: 0.85em; color: #495057;">Fill out by:</label>
        <select name="fields[][restricted_to_type]"
                class="form-control form-control-sm restriction-type-select"
                data-action="change->form-builder#toggleFieldRestriction"
                style="width: auto; min-width: 150px;">
          <option value="none">Anyone (Submitter)</option>
          <option value="employee">Specific Employee</option>
          <option value="group">Group</option>
        </select>

        <div class="restriction-employee-select" style="display: none;">
          <select name="fields[][restricted_to_employee_id]"
                  class="form-control form-control-sm restriction-employee-dropdown"
                  style="min-width: 200px;">
            <option value="">Select employee...</option>
            <% @employees&.each do |emp| %>
              <option value="<%= emp[1] %>"><%= emp[0] %></option>
            <% end %>
          </select>
        </div>

        <div class="restriction-group-select" style="display: none;">
          <select name="fields[][restricted_to_group_id]"
                  class="form-control form-control-sm restriction-group-dropdown"
                  style="min-width: 200px;">
            <option value="">Select group...</option>
            <% @acl_groups&.each do |group| %>
              <option value="<%= group[1] %>"><%= group[0] %></option>
            <% end %>
          </select>
        </div>

        <div class="restriction-org-filter-select" style="display: none;">
          <select name="fields[][restricted_to_org_filter_level]"
                  class="form-control form-control-sm restriction-org-filter-dropdown"
                  style="min-width: 200px;"
                  title="Restrict group members to those matching the submitter at this org level">
            <option value="">Filter by submitter's…</option>
            <% FormTemplateRoutingStep::ORG_FILTER_LEVELS.each do |lvl| %>
              <option value="<%= lvl %>">Filter by submitter's <%= FormTemplateRoutingStep::ORG_FILTER_LABELS[lvl] %></option>
            <% end %>
          </select>
        </div>

        <div class="restriction-visibility-select" style="display: none;">
          <label style="margin: 0 6px 0 0; font-size: 0.85em; color: #495057;">Visible to:</label>
          <select name="fields[][visible_to_filler]"
                  class="form-control form-control-sm restriction-visibility-dropdown"
                  style="width: auto; min-width: 170px;">
            <option value="0">Everyone</option>
            <option value="1">Only the filler</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Conditional Logic Options -->
    <div class="field-options conditional-options" style="margin-top: 10px; padding: 8px; background: #fff3cd; border-radius: 4px; border-left: 3px solid #ffc107;">
      <input type="hidden" name="fields[][conditional_enabled]" class="conditional-enabled-input" value="0">
      <div style="display: flex; gap: 10px; align-items: flex-start; flex-wrap: wrap;">
        <label style="margin: 0; font-size: 0.85em; color: #495057; padding-top: 5px;">
          <input type="checkbox"
                 class="conditional-toggle"
                 data-action="change->form-builder#toggleConditionalOptions"
                 style="margin-right: 5px;">
          Show conditionally
        </label>

        <div class="conditional-config" style="display: none; flex: 1; min-width: 300px;">
          <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin-bottom: 8px;">
            <span style="font-size: 0.85em; color: #495057;">When</span>
            <select class="form-control form-control-sm conditional-field-select"
                    name="fields[][conditional_field_id]"
                    data-action="change->form-builder#updateConditionalValues"
                    style="width: auto; min-width: 150px;">
              <option value="">Select dropdown...</option>
            </select>
            <span style="font-size: 0.85em; color: #495057;">equals:</span>
          </div>
          <div class="conditional-values-container" style="display: flex; flex-wrap: wrap; gap: 8px;">
            <span style="font-size: 0.8em; color: #6c757d; font-style: italic;">Select a dropdown field first</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Repeating Section Options -->
    <div class="field-options repeating-section-options" style="margin-top: 10px; padding: 8px; background: #ede7f6; border-radius: 4px; border-left: 3px solid #6f42c1; display: none;">
      <div style="display: flex; gap: 15px; flex-wrap: wrap; align-items: flex-end;">
        <div>
          <label style="font-size: 0.85em; color: #495057; display: block;">Min entries</label>
          <input type="number" name="fields[][repeat_min]" class="form-control form-control-sm" min="0" value="1" style="width: 90px;">
        </div>
        <div>
          <label style="font-size: 0.85em; color: #495057; display: block;">Max (0 = &infin;)</label>
          <input type="number" name="fields[][repeat_max]" class="form-control form-control-sm" min="0" value="0" style="width: 90px;">
        </div>
        <div style="flex: 1; min-width: 180px;">
          <label style="font-size: 0.85em; color: #495057; display: block;">Add button label</label>
          <input type="text" name="fields[][add_label]" class="form-control form-control-sm" value="" placeholder="+ Add">
        </div>
      </div>
      <small style="display: block; margin-top: 6px; color: #6c757d; font-size: 0.8em;">
        Assign fields to this section using each field's &ldquo;Repeats in section&rdquo; selector. They repeat together as a group with a + button.
      </small>
    </div>

    <!-- Repeat Group Assignment -->
    <div class="field-options repeat-group-row" style="margin-top: 10px;">
      <label style="font-size: 0.85em; color: #495057; margin-right: 6px;">Repeats in section:</label>
      <select class="form-control form-control-sm repeat-group-select" name="fields[][repeat_group]"
              data-action="change->form-builder#handleRepeatGroupChange"
              style="width: auto; min-width: 180px; display: inline-block;">
        <option value="">&mdash; Not in a section &mdash;</option>
      </select>
    </div>

    <!-- Conditional Answer Options (available for any field type) -->
    <div class="field-options conditional-answer-options" style="margin-top: 10px; padding: 8px; background: #d4edda; border-radius: 4px; border-left: 3px solid #28a745;">
      <input type="hidden" name="fields[][conditional_answer_enabled]" class="conditional-answer-enabled-input" value="0">
      <div style="display: flex; gap: 10px; align-items: flex-start; flex-wrap: wrap;">
        <label style="margin: 0; font-size: 0.85em; color: #495057; padding-top: 5px;">
          <input type="checkbox"
                 class="conditional-answer-toggle"
                 data-action="change->form-builder#toggleConditionalAnswerOptions"
                 style="margin-right: 5px;">
          Answer conditionally
        </label>

        <div class="conditional-answer-config" style="display: none; flex: 1; min-width: 300px;">
          <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin-bottom: 8px;">
            <span style="font-size: 0.85em; color: #495057;">When</span>
            <select class="form-control form-control-sm conditional-answer-field-select"
                    name="fields[][conditional_answer_field_id]"
                    data-action="change->form-builder#updateConditionalAnswerMappings"
                    style="width: auto; min-width: 150px;">
              <option value="">Select dropdown...</option>
            </select>
            <span style="font-size: 0.85em; color: #495057;">is selected,</span>
          </div>

          <label style="display: block; font-size: 0.8em; color: #495057; margin-bottom: 8px;">
            <input type="checkbox"
                   class="answer-lookup-toggle"
                   name="fields[][answer_mode]"
                   value="lookup"
                   data-action="change->form-builder#toggleAnswerMode"
                   style="margin-right: 5px;">
            Auto-fill this field from a database table (instead of a fixed answer)
          </label>

          <!-- Static value -> value mapping -->
          <div class="conditional-answer-mappings-container" style="display: flex; flex-direction: column; gap: 6px;">
            <span style="font-size: 0.8em; color: #6c757d; font-style: italic;">Select a trigger dropdown first</span>
          </div>

          <!-- Table-lookup autofill -->
          <div class="answer-lookup-panel" style="display: none; flex-wrap: wrap; gap: 8px; align-items: center;">
            <select class="form-control form-control-sm answer-lookup-database"
                    name="fields[][answer_lookup][database]"
                    data-action="change->form-builder#loadAnswerLookupTables"
                    style="width: auto;">
              <option value="paperboy">Paperboy</option>
              <option value="gsabss">GSABSS (reference)</option>
            </select>
            <select class="form-control form-control-sm answer-lookup-table"
                    name="fields[][answer_lookup][table]"
                    data-action="change->form-builder#loadAnswerLookupColumns"
                    style="width: auto; min-width: 130px;">
              <option value="">Select table...</option>
            </select>
            <span style="font-size: 0.8em; color: #495057;">match on</span>
            <select class="form-control form-control-sm answer-lookup-match-column"
                    name="fields[][answer_lookup][match_column]"
                    style="width: auto; min-width: 120px;">
              <option value="">column...</option>
            </select>
            <span style="font-size: 0.8em; color: #495057;">&rarr; fill with</span>
            <select class="form-control form-control-sm answer-lookup-return-column"
                    name="fields[][answer_lookup][return_column]"
                    style="width: auto; min-width: 120px;">
              <option value="">column...</option>
            </select>
            <div style="flex-basis: 100%; display: flex; gap: 12px; align-items: flex-start; flex-wrap: wrap; margin-top: 4px;">
              <div style="display: flex; flex-direction: column; min-width: 200px;">
                <label style="font-size: 0.8em; color: #495057;">+ also combine columns (optional):</label>
                <div class="answer-lookup-join-chips" style="display: flex; flex-wrap: wrap; gap: 4px; margin: 2px 0;"></div>
                <select class="form-control form-control-sm answer-lookup-return-join-add"
                        data-action="change->form-builder#addAnswerJoinColumn"
                        style="width: auto; min-width: 180px;">
                  <option value="">+ add a column&hellip;</option>
                </select>
                <small style="display: block; color: #6c757d; font-size: 0.75em; margin-top: 2px;">Pick columns to append to the fill column above (e.g. first + last name).</small>
              </div>
              <div style="display: flex; flex-direction: column; min-width: 90px;">
                <label style="font-size: 0.8em; color: #495057;">Join separator:</label>
                <input type="text" class="form-control form-control-sm answer-lookup-return-separator"
                       name="fields[][answer_lookup][return_join_separator]"
                       value=" " placeholder="(space)" style="width: 90px;">
                <small style="display: block; color: #6c757d; font-size: 0.75em; margin-top: 2px;">Placed between joined values. Defaults to a space.</small>
              </div>
            </div>
            <small style="flex-basis: 100%; font-size: 0.75em; color: #6c757d; font-style: italic;">
              The trigger's displayed value is matched against the match column, so the trigger should list values from this same table/column. First matching row wins.
            </small>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<!-- Routing Step Template (hidden, used for cloning) -->
<template id="routing-step-template">
  <div class="routing-step-item" data-form-builder-target="routingStepItem" style="background: #f0f4f8; padding: 12px; margin-bottom: 10px; border-radius: 6px; border-left: 3px solid #007bff;">
    <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
      <div class="routing-step-drag-handle" title="Drag to reorder" style="display: flex; flex-direction: column; align-items: center; justify-content: center; cursor: grab; padding: 6px 10px; background: #dde6f1; border-radius: 4px; min-width: 60px;">
        <span class="step-number" style="font-size: 12px; font-weight: 700; color: #495057;">Step 1</span>
        <span style="font-size: 14px; color: #6c757d;">&#x2630;</span>
      </div>

      <div style="flex: 1; min-width: 150px;">
        <select name="routing_steps[][routing_type]"
                class="form-control form-control-sm routing-type-select"
                data-action="change->form-builder#toggleStepEmployeeSelect"
                required>
          <option value="">Select...</option>
          <option value="supervisor">Supervisor</option>
          <option value="department_head">Department Head</option>
          <option value="employee">Specific Employee</option>
          <option value="group">Group</option>
          <option value="authorization">Authorization Console</option>
        </select>
      </div>

      <div class="step-authorization-select" style="flex: 1; min-width: 220px; display: none;">
        <select name="routing_steps[][authorization_service_type]"
                class="form-control form-control-sm step-authorization-dropdown"
                data-action="change->form-builder#updateStepDisplayName"
                title="Route to whoever holds this authorization for the submitter's budget unit">
          <option value="">Select authorization…</option>
          <% AuthorizedApprover::SERVICE_TYPES.each do |code, label| %>
            <option value="<%= code %>"><%= label %></option>
          <% end %>
        </select>
      </div>

      <div class="step-employee-select" style="flex: 1; min-width: 200px; display: none;">
        <select name="routing_steps[][employee_id]"
                class="form-control form-control-sm step-employee-dropdown"
                data-action="change->form-builder#updateStepDisplayName">
          <option value="">Select employee...</option>
        </select>
      </div>

      <div class="step-group-select" style="flex: 1; min-width: 200px; display: none;">
        <select name="routing_steps[][group_id]"
                class="form-control form-control-sm step-group-dropdown"
                data-action="change->form-builder#updateStepDisplayName">
          <option value="">Select group...</option>
        </select>
      </div>

      <div class="step-org-filter-select" style="flex: 1; min-width: 200px; display: none;">
        <select name="routing_steps[][org_filter_level]"
                class="form-control form-control-sm step-org-filter-dropdown"
                data-action="change->form-builder#updateStepDisplayName"
                title="Restrict group members to those matching the submitter at this org level">
          <option value="">Filter by submitter's…</option>
          <% FormTemplateRoutingStep::ORG_FILTER_LEVELS.each do |lvl| %>
            <option value="<%= lvl %>">Filter by submitter's <%= FormTemplateRoutingStep::ORG_FILTER_LABELS[lvl] %></option>
          <% end %>
        </select>
      </div>

      <div class="step-display-name" style="flex: 1; min-width: 180px;">
        <input type="text" name="routing_steps[][display_name]"
               class="form-control form-control-sm step-display-name-input"
               placeholder="e.g. Sent to HR (auto-generated if blank)">
      </div>

      <input type="hidden" name="routing_steps[][step_number]" class="step-number-input" value="1">

      <button type="button"
              class="btn deny"
              data-action="click->form-builder#removeRoutingStep"
              style="padding: 4px 8px;">
        Remove
      </button>
    </div>

    <div class="step-condition-row" style="margin-top: 8px; padding: 8px; background: #fff; border-radius: 4px; border-left: 2px solid #6c757d;">
      <div style="display: flex; gap: 8px; align-items: center; flex-wrap: wrap;">
        <label style="margin: 0; font-size: 0.85em; color: #495057; display: flex; align-items: center; gap: 4px;">
          <input type="checkbox"
                 class="step-condition-toggle"
                 data-action="change->form-builder#toggleStepCondition">
          Only run this step if
        </label>

        <select name="routing_steps[][condition_field_name]"
                class="form-control form-control-sm step-condition-field"
                data-action="change->form-builder#updateStepConditionValue"
                style="width: auto; min-width: 160px; display: none;">
          <option value="">Select field...</option>
        </select>

        <select name="routing_steps[][condition_operator]"
                class="form-control form-control-sm step-condition-operator"
                style="width: auto; display: none;">
          <option value="equals">equals</option>
          <option value="not_equals">does not equal</option>
        </select>

        <span class="step-condition-value-wrapper" style="display: none;">
          <input type="text"
                 name="routing_steps[][condition_value]"
                 class="form-control form-control-sm step-condition-value"
                 placeholder="value">
        </span>
      </div>
    </div>

    <div class="step-inbox-buttons-row" style="margin-top: 8px; padding: 8px; background: #fff; border-radius: 4px; border-left: 2px solid #007bff;">
      <div style="font-size: 0.85em; color: #495057; font-weight: 600; margin-bottom: 6px;">Inbox queue buttons at this step</div>
      <div class="step-inbox-buttons-grid" style="display: flex; flex-wrap: wrap; gap: 8px;">
        <% FormTemplate::INBOX_BUTTON_TYPES.each do |key, config| %>
          <label style="flex: 0 0 calc(50% - 8px); display: flex; align-items: flex-start; gap: 6px; margin: 0; font-size: 0.85em; cursor: pointer;">
            <input type="checkbox"
                   name="routing_steps[][inbox_buttons][]"
                   value="<%= key %>"
                   class="step-inbox-button-checkbox"
                   style="margin-top: 3px;">
            <span>
              <strong><%= config[:label] %></strong>
              <small style="display: block; color: #6c757d; font-weight: normal;"><%= config[:description] %></small>
            </span>
          </label>
        <% end %>
      </div>
      <div class="step-button-labels" style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 8px;">
        <label style="flex: 1; min-width: 140px; font-size: 0.85em; color: #495057;">
          Approve button label
          <input type="text"
                 name="routing_steps[][approve_button_label]"
                 class="form-control form-control-sm step-approve-button-label"
                 placeholder="Approve">
          <small style="display: block; color: #6c757d;">Optional — e.g. "Permit Printed". Still advances the workflow.</small>
        </label>
        <label style="flex: 1; min-width: 140px; font-size: 0.85em; color: #495057;">
          Deny button label
          <input type="text"
                 name="routing_steps[][deny_button_label]"
                 class="form-control form-control-sm step-deny-button-label"
                 placeholder="Deny">
          <small style="display: block; color: #6c757d;">Optional. Leave blank for the default "Deny".</small>
        </label>
      </div>
    </div>
  </div>
</template>

<!-- Copy Recipient Template (hidden, used for cloning) -->
