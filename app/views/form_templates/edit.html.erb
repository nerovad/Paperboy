<!-- Email Notification Template (hidden, used for cloning) -->
<template id="email-step-template">
  <div class="email-step-item" data-form-builder-target="emailStepItem" style="background: #f0f4f8; padding: 12px; margin-bottom: 10px; border-radius: 6px; border-left: 3px solid #17a2b8;">
    <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
      <div style="flex: 0 0 160px;">
        <select name="email_steps[][trigger_event]"
                class="form-control form-control-sm email-step-trigger"
