<!-- app/views/admin/impersonations/new.html.erb -->
<div class="form-header">
  <h1>🎭 Emulate User</h1>
</div>

<div class="form-wrapper impersonation-wrapper">
  <%= form_with url: admin_impersonations_path, method: :post do |f| %>
    <%= f.label :employee_id, "Select Employee:" %>
    <div data-controller="choices">
      <%= f.select :employee_id,
                   @employees.map { |e| ["#{e.first_name} #{e.last_name} (#{e.employee_id})", e.employee_id] },
                   { prompt: "Choose an employee..." },
                   { class: "form-control", data: { choices_target: "select", placeholder: "Search for an employee..." } } %>
    </div>

    <%= f.submit "Emulate", class: "btn-impersonate" %>
    <%= link_to "Cancel", root_path, class: "btn-back" %>
  <% end %>
</div>
