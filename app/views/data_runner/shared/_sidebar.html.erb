<div class="sidebar data-runner-sidebar" data-controller="sidebar-search dsl-drag">
  <%= link_to "DataRunner", data_runner_root_path, class: "brand" %>
  <% if user_signed_in? %>
    <input class="sidebar-search-input" type="search" placeholder="Fuzzy search DSLs..."
           data-sidebar-search-target="input" data-action="input->sidebar-search#filter">
    <nav>
      <% DslCatalog.grouped.each do |group, entries| %>
        <details class="nav-group" data-nav-group="<%= group %>"
                 <%= "open" if @selected_group == group || entries.any? { |entry| @dsl&.slug == entry.slug } %>>
          <summary><%= link_to group.humanize, data_runner_root_path(group: group), class: "nav-group-link" %></summary>
          <% entries.each do |entry| %>
            <div class="nav-link <%= 'active' if @dsl&.slug == entry.slug %>" role="link" tabindex="0"
                 onmousedown="window.DataRunnerStartDslDrag && window.DataRunnerStartDslDrag(event, this, 'nav')"
                 data-action="click->dsl-drag#open keydown->dsl-drag#open mousedown->dsl-drag#mousedown"
                 data-sidebar-search-target="item" data-search="<%= "#{entry.key} #{group} #{entry.slug}" %>"
                 data-dsl-slug="<%= entry.slug %>" data-dsl-key="<%= entry.key %>" data-dsl-enabled="<%= entry.enabled? %>"
                 data-href="<%= data_runner_dsl_path(entry.slug) %>"><%= entry.key %></div>
          <% end %>
        </details>
      <% end %>
      <details class="nav-group">
        <summary><span class="nav-group-label">Other DSLs</span></summary>
        <% DslCatalog.ungrouped.each do |entry| %>
          <div class="nav-link <%= 'active' if @dsl&.slug == entry.slug %>" role="link" tabindex="0"
               onmousedown="window.DataRunnerStartDslDrag && window.DataRunnerStartDslDrag(event, this, 'nav')"
               data-action="click->dsl-drag#open keydown->dsl-drag#open mousedown->dsl-drag#mousedown"
               data-sidebar-search-target="item" data-search="<%= "#{entry.key} #{entry.slug}" %>"
               data-dsl-slug="<%= entry.slug %>" data-dsl-key="<%= entry.key %>" data-dsl-enabled="<%= entry.enabled? %>"
               data-href="<%= data_runner_dsl_path(entry.slug) %>"><%= entry.key %></div>
        <% end %>
      </details>
    </nav>
  <% else %>
    <p class="sidebar-p">Please log in to access DataRunner.</p>
  <% end %>
</div>
