<!-- app/views/acl/edit_contractor.html.erb -->
<div class="form-header">
  <h1>Edit Contractor</h1>
</div>

<div class="form-wrapper">
  <div class="acl-header">
    <p class="acl-subtitle"><%= @contractor.full_name %> &middot; <%= @contractor.email %></p>
    <%= link_to "Back to #{@group.group_name}", acl_path(@group), class: "btn" %>
  </div>

  <%= form_with url: update_contractor_acl_path(@group, contractor_id: @contractor.id),
        method: :patch, scope: :contractor, model: @contractor, local: true do |f| %>
    <div class="acl-contractor-grid">
      <div class="form-group">
        <%= f.label :first_name, "First name" %>
        <%= f.text_field :first_name, required: true, class: "form-control" %>
      </div>
      <div class="form-group">
        <%= f.label :last_name, "Last name" %>
        <%= f.text_field :last_name, required: true, class: "form-control" %>
      </div>
      <div class="form-group">
        <%= f.label :email, "Email" %>
        <%= f.email_field :email, required: true, class: "form-control" %>
      </div>
      <div class="form-group">
        <%= f.label :work_phone, "Phone" %>
        <%= f.telephone_field :work_phone, class: "form-control" %>
      </div>
      <div class="form-group">
        <%= f.label :agency, "Agency (business unit)" %>
        <%= f.select :agency, options_for_select(@agency_options, @contractor.agency), { include_blank: "— Select agency —" }, class: "form-control" %>
      </div>
      <div class="form-group">
        <%= f.label :unit, "Unit code" %>
        <%= f.text_field :unit, class: "form-control" %>
      </div>
      <div class="form-group">
        <%= f.label :supervisor_id, "Supervisor (employee ID)" %>
        <%= f.text_field :supervisor_id, class: "form-control" %>
      </div>
      <div class="form-group">
        <%= f.label :expires_at, "Access expires" %>
        <%= f.date_field :expires_at, value: @contractor.expires_at&.to_date, class: "form-control" %>
      </div>
    </div>

    <div class="form-actions">
      <%= f.submit "Save Changes", class: "btn approve" %>
      <%= link_to "Cancel", acl_path(@group), class: "btn" %>
    </div>
  <% end %>
</div>
