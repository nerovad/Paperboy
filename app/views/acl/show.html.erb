<!-- app/views/acl/show.html.erb -->
<div class="form-header">
  <h1><%= @group.group_name %></h1>
</div>

<div class="form-wrapper acl-management" data-controller="confirm-modal">
  <div class="acl-header">
    <p class="acl-subtitle"><%= @group.description %></p>
    <%= link_to "Back to Groups", acl_index_path, class: "btn" %>
  </div>

  <!-- Add Member Search -->
  <div class="acl-search-section">
    <h3>Add Member</h3>
    <%= form_tag acl_path(@group), method: :get, class: "acl-search-form" do %>
      <div class="acl-search-row">
        <%= text_field_tag :search, params[:search],
              placeholder: "Search by name or employee ID...",
              class: "form-control acl-search-input" %>
        <%= submit_tag "Search", class: "btn approve" %>
      </div>
    <% end %>

    <% if @search_results&.any? %>
      <table class="submission-table acl-search-results">
        <thead>
          <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Email</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @search_results.each do |emp| %>
            <tr>
              <td><%= emp.employee_id %></td>
              <td><%= emp.first_name %> <%= emp.last_name %></td>
              <td><%= emp.email %></td>
              <td class="action-buttons">
                <% if @group.employee_groups.exists?(employee_id: emp.employee_id) %>
                  <span class="acl-already-member">Already a member</span>
                <% else %>
                  <%= form_tag add_member_acl_path(@group), method: :post do %>
                    <%= hidden_field_tag :employee_id, emp.employee_id %>
                    <%= submit_tag "Add", class: "btn approve" %>
                  <% end %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% elsif params[:search].present? %>
      <p class="acl-no-results">No employees found matching "<%= params[:search] %>".</p>
    <% end %>
  </div>

  <!-- Add Contractor (non-Active-Directory user) -->
  <div class="acl-search-section">
    <h3>Add Contractor</h3>
    <p class="form-intro">
      Contractors don't have a Microsoft (AD) account. Creating one here adds
      them to this group and emails them a link to set their password.
    </p>

    <%= form_with model: Contractor.new, url: add_contractor_acl_path(@group), method: :post, local: true do |f| %>
      <%= render "contractor_fields", f: f %>
      <div class="form-actions">
        <%= f.submit "Create Contractor & Send Invite", class: "btn approve" %>
      </div>
    <% end %>
  </div>

  <!-- Contractor Members -->
  <% if @contractor_members.any? %>
    <div class="acl-members-section">
      <h3>Contractor Members (<%= @contractor_members.size %>)</h3>
      <table class="submission-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Email</th>
            <th>Status</th>
            <th>Expires</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @contractor_members.each do |contractor| %>
            <tr>
              <td><%= contractor.id %></td>
              <td><%= contractor.full_name %></td>
              <td><%= contractor.email %></td>
              <td>
                <% if !contractor.active? %>
                  <span class="badge is-cancelled">Inactive</span>
                <% elsif contractor.expired? %>
                  <span class="badge is-cancelled">Expired</span>
                <% elsif contractor.password_digest.blank? %>
                  <span class="badge is-pending">Invite sent</span>
                <% else %>
                  <span class="badge is-approved">Active</span>
                <% end %>
              </td>
              <td><%= contractor.expires_at&.to_date %></td>
              <td class="action-buttons">
                <%= link_to "Edit", edit_contractor_acl_path(@group, contractor_id: contractor.id), class: "btn" %>
                <%= button_to "Resend invite", resend_contractor_welcome_acl_path(@group, contractor_id: contractor.id), method: :post, class: "btn" %>
                <%= button_to (contractor.active? ? "Deactivate" : "Reactivate"),
                      toggle_contractor_acl_path(@group, contractor_id: contractor.id), method: :patch,
                      class: (contractor.active? ? "btn deny" : "btn approve") %>
                <button type="button"
                        class="btn deny"
                        data-action="click->confirm-modal#open"
                        data-delete-path="<%= remove_member_acl_path(@group, employee_id: contractor.id) %>"
                        data-confirm-title="Remove Contractor"
                        data-confirm-message="Remove <%= contractor.full_name %> from <%= @group.group_name %>? (This only removes group membership; the account is kept.)">
                  Remove
                </button>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <!-- Current Members -->
  <div class="acl-members-section">
    <h3>Members (<%= @members.size %>)</h3>

    <% if @members.any? %>
      <table class="submission-table">
        <thead>
          <tr>
            <th>Employee ID</th>
            <th>Name</th>
            <th>Email</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @members.each do |member| %>
            <tr>
              <td><%= member.employee_id %></td>
              <td><%= member.first_name %> <%= member.last_name %></td>
              <td><%= member.email %></td>
              <td class="action-buttons">
                <button type="button"
                        class="btn deny"
                        data-action="click->confirm-modal#open"
                        data-delete-path="<%= remove_member_acl_path(@group, employee_id: member.employee_id) %>"
                        data-confirm-title="Remove Member"
                        data-confirm-message="Remove <%= member.first_name %> <%= member.last_name %> from <%= @group.group_name %>?">
                  Remove
                </button>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="empty-state">
        <p>No members in this group yet.</p>
        <p class="empty-state-hint">Use the search above to find and add employees.</p>
      </div>
    <% end %>
  </div>

  <%= render "shared/confirm_modal" %>
</div>
