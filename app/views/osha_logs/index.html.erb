<div class="form-header">
  <h1>OSHA Form 300 &mdash; Log of Work-Related Injuries and Illnesses</h1>
</div>

<div class="form-wrapper">
  <div class="form-row d-flex flex-wrap" style="align-items: end; gap: 12px; margin-bottom: 16px;">
    <%= form_with url: osha_log_path, method: :get, local: true, data: { turbo: false } do |f| %>
      <div class="form-group" style="margin-right: 8px;">
        <%= f.label :year, "Year" %>
        <%= f.select :year,
              options_for_select(@available_years.map { |y| [y, y] }, @year),
              {},
              class: "form-control" %>
      </div>
      <%= f.submit "Apply", class: "btn approve" %>
    <% end %>

    <%= link_to "Export CSV",
          osha_log_path(year: @year, format: :csv),
          class: "btn pdf",
          data: { turbo: false } %>
  </div>

  <p style="margin-bottom: 12px; color: #555;">
    Showing <strong><%= @rows.size %></strong> approved
    <%= "case".pluralize(@rows.size) %> for <strong><%= @year %></strong>.
  </p>

  <table class="data-table">
    <thead>
      <tr>
        <th>Case #</th>
        <th>Employee Name</th>
        <th>Job Title</th>
        <th>Date of Injury</th>
        <th>Activity at Time of Incident</th>
        <th>Description of Injury/Illness</th>
        <th>Death?</th>
        <th>Days Away</th>
        <th>Report</th>
      </tr>
    </thead>
    <tbody>
      <% if @rows.any? %>
        <% @rows.each do |row| %>
          <tr>
            <td><%= row[:case_number] %></td>
            <td><%= row[:employee_name] %></td>
            <td><%= row[:job_title].presence || "&mdash;".html_safe %></td>
            <td><%= row[:date_of_injury]&.strftime("%b %d, %Y") %></td>
            <td><%= row[:activity].presence || "&mdash;".html_safe %></td>
            <td><%= row[:description].presence || "&mdash;".html_safe %></td>
            <td><%= row[:died] ? "Yes" : "No" %></td>
            <td><%= row[:days_away] || "&mdash;".html_safe %></td>
            <td><%= link_to "View", osha_report_path(row[:report_id]), data: { turbo: false } %></td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="9" style="text-align: center; padding: 16px;">
            No approved OSHA reports for <%= @year %>.
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <p style="margin-top: 18px; font-size: 0.9em; color: #777;">
    Not yet populated: case classification (Death / Days Away from Work / Job
    Transfer / Other Recordable), restricted-duty days, and injury vs. illness
    type. These need additional fields on the OSHA report or computed logic
    over the linked Safety Report; will be wired up next.
  </p>
</div>
