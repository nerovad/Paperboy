<!-- app/views/authorization_console/index.html.erb -->
<div class="form-header">
  <h1>Authorization Console</h1>
</div>

<div class="form-wrapper authorization-console" data-controller="confirm-modal">
  <% if @managed_departments.any? %>
    <div class="console-filters">
      <%= form_with url: authorization_console_index_path, method: :get, data: { turbo: false, controller: "auto-submit" } do %>
        <% if @managed_departments.size > 1 %>
          <div class="filter-group" data-controller="choices">
            <label>Budget Unit</label>
            <%= select_tag :department_id,
                  options_for_select(
                    @managed_departments.map { |d| ["#{d.department_id} - #{d.long_name}", d.department_id] },
                    @department_ids
                  ),
                  multiple: true,
                  class: "form-control",
                  data: { choices_target: "select", action: "change->auto-submit#submit", placeholder: "All Budget Units" } %>
          </div>
        <% end %>

        <div class="filter-group" data-controller="choices">
          <label>Employee</label>
          <%= select_tag :employee_id,
                options_for_select(@employee_filter_options, @employee_id_filter),
                multiple: true,
                class: "form-control",
                data: { choices_target: "select", action: "change->auto-submit#submit", placeholder: "All Employees" } %>
        </div>

        <div class="filter-group" data-controller="choices">
          <label>Service Type</label>
          <%= select_tag :service_type,
                options_for_select(@service_type_filter_options, @service_type_filter),
                multiple: true,
                class: "form-control",
                data: { choices_target: "select", action: "change->auto-submit#submit", placeholder: "All Service Types" } %>
        </div>

        <div class="filter-group" data-controller="choices">
          <label>Location</label>
          <%= select_tag :location,
                options_for_select(@location_filter_options.map { |l| [l, l] }, @location_filter),
                multiple: true,
                class: "form-control",
                data: { choices_target: "select", action: "change->auto-submit#submit", placeholder: "All Locations" } %>
        </div>
      <% end %>
    </div>

    <div class="department-header">
      <%= link_to "+ Add New Authorized Approver",
            new_authorization_console_path(department_id: @department_ids.first || @managed_departments.first&.department_id),
            class: "btn approve" %>
      <%= link_to "Export CSV",
            authorization_console_index_path(format: :csv, department_id: @department_ids,
              employee_id: @employee_id_filter, service_type: @service_type_filter, location: @location_filter),
            class: "btn pdf", data: { turbo: false } %>
    </div>

    <div class="approvers-scroll">
    <% if @groups_by_employee.any? %>
      <div class="approvers-list">
        <% @groups_by_employee.each do |employee_id, groups| %>
          <% employee = groups.first[:record].employee %>
          <div class="approver-card">
            <div class="approver-header">
              <h3>
                <%= employee&.first_name %> <%= employee&.last_name %>
                <span class="employee-id">(<%= employee_id %>)</span>
              </h3>
            </div>

            <div class="approvals-list">
              <% groups.each do |group| %>
                <% a = group[:record] %>
                <div class="approval-item">
                  <div class="approval-details">
                    <strong>
                      <%= group[:service_types].map { |s| "#{AuthorizedApprover::SERVICE_TYPES[s]} (#{s})" }.join(", ") %>
                    </strong>

                    <% if group[:key_types].any? %>
                      <div class="detail-row">
                        <span class="label">Key Types:</span>
                        <span class="value"><%= group[:key_types].map { |k| AuthorizedApprover::KEY_TYPES[k] || k }.join(", ") %></span>
                      </div>
                    <% end %>

                    <% if a.span.present? %>
                      <div class="detail-row">
                        <span class="label">Scope:</span>
                        <span class="value"><%= a.span_label %></span>
                      </div>
                    <% end %>

                    <% if a.budget_units.present? %>
                      <div class="detail-row">
                        <span class="label">Budget Units:</span>
                        <span class="value"><%= a.budget_units %></span>
                      </div>
                    <% end %>

                    <% if a.locations.present? %>
                      <div class="detail-row">
                        <span class="label">Locations:</span>
                        <span class="value"><%= Array(a.locations).join(", ") %></span>
                      </div>
                    <% end %>
                  </div>

                  <div class="approval-actions">
                    <%= link_to "Edit",
                          group_edit_authorization_console_index_path(ids: group[:ids]),
                          class: "btn" %>
                    <button type="button"
                            class="btn deny"
                            data-action="click->confirm-modal#open"
                            data-delete-path="<%= group_destroy_authorization_console_index_path(ids: group[:ids]) %>"
                            data-confirm-title="Remove Authorization"
                            data-confirm-message="Remove this authorization (<%= group[:service_types].join("/") %>) for <%= employee&.first_name %> <%= employee&.last_name %>?">
                      Remove
                    </button>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state">
        <p>No authorized approvers have been assigned yet.</p>
        <p class="empty-state-hint">Click "+ Add New Authorized Approver" to get started.</p>
      </div>
    <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <p>No departments assigned to manage.</p>
    </div>
  <% end %>
  <%= render "shared/confirm_modal" %>
</div>
