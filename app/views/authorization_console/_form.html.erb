<%= form_with model: @authorized_approver, url: form_url, method: (local_assigns[:form_method] || :post), data: { turbo: false } do |form| %>
  <% if @authorized_approver.errors.any? %>
    <div class="alert alert-danger">
      <p><strong>There was a problem:</strong></p>
      <ul>
        <% @authorized_approver.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% Array(local_assigns[:original_ids]).each do |oid| %>
    <%= hidden_field_tag "ids[]", oid %>
  <% end %>

  <%= form.hidden_field :department_id, value: @department_id %>

  <div class="form-group" data-controller="choices">
    <%= form.label :employee_id, "Employee" %>
    <%= form.select :employee_id,
          options_for_select(@department_employees.map { |e| [e[:name], e[:id]] }, @authorized_approver.employee_id),
          { prompt: "Select Employee" },
          class: "form-control",
          required: true,
          data: { choices_target: "select", placeholder: "Search for an employee..." } %>
  </div>

  <!-- Service types + key types share the toggle controller -->
  <div data-controller="authorization-select">
    <div class="form-group" data-controller="choices">
      <%= form.label :service_type, "Service Type" %>
      <%= form.select :service_type,
            options_for_select(AuthorizedApprover::SERVICE_TYPES.map { |k, v| ["#{v} (#{k})", k] }, @selected_service_types || []),
            {},
            multiple: true,
            class: "form-control",
            required: true,
            data: {
              authorization_select_target: "serviceType",
              choices_target: "select",
              action: "change->authorization-select#toggleFields",
              placeholder: "Select service type(s)…"
            } %>
    </div>

    <div class="form-group"
         data-authorization-select-target="keyTypeWrapper"
         data-controller="choices"
         style="display:none;">
      <label>Key Types</label>
      <%= select_tag "authorized_approver[key_types][]",
            options_for_select(AuthorizedApprover::KEY_TYPES.map { |k, v| ["#{k} = #{v}", k] }, @selected_key_types || []),
            multiple: true,
            class: "form-control",
            data: {
              authorization_select_target: "keyType",
              choices_target: "select",
              placeholder: "Select key type(s)…"
            } %>
      <small class="help-text">Applies to Facility Keys &amp; Security Access (K)</small>
    </div>
  </div>

  <div class="form-group">
    <%= form.label :span, "Authorization Span" %>
    <%= form.select :span,
          options_for_select(AuthorizedApprover::SPANS.map { |k, v| ["#{k} = #{v}", k] }, @authorized_approver.span),
          { prompt: "Select Span" },
          class: "form-control" %>
  </div>

  <div class="form-group" data-controller="choices">
    <%= form.label :budget_units, "Budget Units" %>
    <%= form.select :budget_units,
          options_for_select((@budget_unit_options || []), @authorized_approver.budget_units&.split(",")),
          {},
          multiple: true,
          class: "form-control",
          data: { choices_target: "select", placeholder: "Select budget unit(s)…" } %>
    <small class="help-text">Leave blank to allow all budget units</small>
  </div>

  <div class="form-group" data-controller="choices">
    <%= form.label :locations, "Locations" %>
    <%= form.select :locations,
          options_for_select((@location_options || []), @authorized_approver.locations),
          {},
          multiple: true,
          class: "form-control",
          data: { choices_target: "select", placeholder: "Select location(s)…" } %>
    <small class="help-text">Leave blank to allow all locations</small>
  </div>

  <div class="form-actions">
    <%= link_to "Cancel", authorization_console_index_path(department_id: @department_id), class: "btn" %>
    <%= form.submit submit_label, class: "btn approve" %>
  </div>
<% end %>
