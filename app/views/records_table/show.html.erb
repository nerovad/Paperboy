<div class="records-screen">
  <%= render "shared/work_tabs", active: :records %>

  <div class="records-head">
    <%= link_to "← Records", records_path, class: "records-back" %>
    <h1 class="records-title"><%= @table.label %></h1>
  </div>

  <%= render 'records/toolbar', path: records_table_path(@table.slug), page: @page,
             columns: @columns, filter_options: @filter_options %>

  <%= render 'records/grid', table: @table, page: @page, columns: @columns, rows: @records %>
</div>
