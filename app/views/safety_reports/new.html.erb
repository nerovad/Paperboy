<!-- Generated by Paperboy Form Builder -->
<div class="form-header">
  <h1>Safety Reporting</h1>
</div>

<div class="form-wrapper" data-controller="form-navigation conditional-fields">
  <%= form_with model: @safety_report, local: true do |form| %>

  <% if @safety_report.errors.any? %>
    <div class="form-errors" role="alert" data-form-navigation-target="errorSummary">
      <strong><%= pluralize(@safety_report.errors.count, "error") %> prevented this form from being submitted:</strong>
      <ul>
        <% @safety_report.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

        <% _page_1_visible = true %>
        <% _page_2_visible = true %>
        <% _page_3_visible = true %>
        <% _page_4_visible = true %>
        <% _page_5_visible = true %>
        <% _page_6_visible = true %>
        <% _page_7_visible = true %>
        <% _page_8_visible = (@current_user_groups&.include?(19) || system_admin?) %>
        <% _page_9_visible = (@current_user_groups&.include?(19) || system_admin?) %>
        <% _page_10_visible = (@current_user_groups&.include?(19) || system_admin?) %>
        <% _page_11_visible = (@current_user_groups&.include?(19) || system_admin?) %>
        <% _visible_page_count = [_page_1_visible, _page_2_visible, _page_3_visible, _page_4_visible, _page_5_visible, _page_6_visible, _page_7_visible, _page_8_visible, _page_9_visible, _page_10_visible, _page_11_visible].count(true) %>

<!-- Page 1: Employee Info -->
<div class="form-page">
  <h2>Employee Info</h2>
<div class="form-row d-flex flex-wrap">
  <div class="form-group flex-fill">
    <%= form.label :employee_id, "Employee ID" %>
    <%= form.text_field :employee_id,
          value: @prefill_data[:employee_id],
          class: "form-control",
          readonly: true %>
  </div>

  <div class="form-group flex-fill">
    <%= form.label :name, "Name" %>
    <%= form.text_field :name,
          value: @prefill_data[:name],
          class: "form-control",
          readonly: true %>
  </div>

  <div class="form-group flex-fill">
    <%= form.label :phone, "Phone" %>
    <%= form.text_field :phone,
          value: @prefill_data[:phone],
          class: "form-control",
          required: true,
          placeholder: "e.g. 555-555-5555",
          title: "Enter a 10-digit phone number like 555-555-5555",
          data: {
            controller: "phone",
            phone_target: "input",
            action: "input->phone#format paste->phone#format blur->phone#validate"
          },
          "aria-describedby": "phoneHelp phoneError",
          pattern: "\\d{3}-\\d{3}-\\d{4}",
          inputmode: "numeric",
          autocomplete: "tel" %>
    <small id="phoneHelp" class="help-text text-muted"></small>
    <div id="phoneError" data-phone-target="error" class="field-error" aria-live="polite"></div>
  </div>

  <div class="form-group flex-fill">
    <%= form.label :email, "Email" %>
    <%= form.text_field :email,
          value: @prefill_data[:email],
          class: "form-control",
          required: true %>
  </div>
</div>
      </div>

