        <% _page_1_visible = true %>
        <% _page_2_visible = true %>
        <% _page_3_visible = true %>
        <% _page_4_visible = true %>
        <% _page_5_visible = true %>
        <% _page_6_visible = true %>
        <% _page_7_visible = true %>
