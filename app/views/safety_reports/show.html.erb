<div class="form-header">
  <h1>Safety Reporting</h1>
</div>

<div class="form-wrapper">
  <div class="form-inner">

  <%= render partial: "shared/readonly_record",
             locals: { record: @safety_report,
                       exclude: %w[id created_at updated_at approver_id deny_reason] } %>

  <% if @safety_report.osha_report.present? %>
    <div class="form-group" style="margin-top: 16px;">
      <strong>Generated OSHA Report:</strong>
      <%= link_to "View OSHA Report ##{@safety_report.osha_report.id}", osha_report_path(@safety_report.osha_report) %>
    </div>
  <% end %>

  <div class="form-actions" style="margin-top: 16px;">
    <%= link_to "Back to Inbox", inbox_queue_path, class: "form-btn" %>
    <%= link_to "Download PDF", pdf_safety_report_path(@safety_report), target: "_blank", class: "form-btn" %>
  </div>
  </div>
</div>
